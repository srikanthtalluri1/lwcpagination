@IsTest
private class technologyDecision_CreateFormHelperTest {
    static User runAsUserRec;
    static UCH_Employee__c runAsEmp;
    static UCH_Employee__c taEmp;
    static UCH_Employee__c boEmp;
    static UCH_Employee__c aoEmp;
    static UCH_Employee__c tfEmp;

    @TestSetup
    static void setupData() {
        Profile p = [SELECT Id FROM Profile WHERE Name = 'Standard User' LIMIT 1];

        String uniq = String.valueOf(System.currentTimeMillis());

        runAsUserRec = new User(
            Alias = 'tdusr',
            Email = 'tdusr' + uniq + '@example.com',
            EmailEncodingKey = 'UTF-8',
            LastName = 'TD User',
            LanguageLocaleKey = 'en_US',
            LocaleSidKey = 'en_US',
            TimeZoneSidKey = 'America/Chicago',
            ProfileId = p.Id,
            Username = 'tdusr' + uniq + '@example.com',
            EmployeeNumber = 'EMP' + uniq.right(6)
        );
        insert runAsUserRec;

        runAsEmp = new UCH_Employee__c(
            Name = 'Run As Emp',
            Employee_ID__c = runAsUserRec.EmployeeNumber,
            Employee_Email_Address__c = 'runas' + uniq + '@example.com'
        );
        insert runAsEmp;

        taEmp = new UCH_Employee__c(
            Name = 'TA Emp',
            Employee_ID__c = 'TA' + uniq.right(6),
            Employee_Email_Address__c = 'ta' + uniq + '@example.com'
        );
        insert taEmp;

        boEmp = new UCH_Employee__c(
            Name = 'BO Emp',
            Employee_ID__c = 'BO' + uniq.right(6),
            Employee_Email_Address__c = 'bo' + uniq + '@example.com'
        );
        insert boEmp;

        aoEmp = new UCH_Employee__c(
            Name = 'AO Emp',
            Employee_ID__c = 'AO' + uniq.right(6),
            Employee_Email_Address__c = 'ao' + uniq + '@example.com'
        );
        insert aoEmp;

        tfEmp = new UCH_Employee__c(
            Name = 'TF Emp',
            Employee_ID__c = 'TF' + uniq.right(6),
            Employee_Email_Address__c = 'tf' + uniq + '@example.com'
        );
        insert tfEmp;
    }

    private static Id getEmpId() {
        AWP_Utility.loggedInUserRecord = null;
        return AWP_Utility.getLoggedInUserEmpRecordId();
    }

    private static TPM_Domain__c createDomain() {
        TPM_Domain__c dom = new TPM_Domain__c(
            Name = 'Domain ' + System.now().getTime()
        );
        insert dom;
        return dom;
    }

    private static TPM_App__c createApp() {
        TPM_App__c app = new TPM_App__c(
            Name = 'App ' + System.now().getTime(),
            Is_Assessment_Present__c = true,
            Application_Type__c = 'Application Services',
            IT_Architect_Delegate_1__c = taEmp.Id,
            IT_Architect_Delegate_2__c = boEmp.Id
        );
        insert app;
        return app;
    }

    private static TechnologyDecision_Relationship__c createRelationship() {
        TPM_Domain__c dom = createDomain();
        TPM_App__c app = createApp();

        TechnologyDecision_Relationship__c rel = new TechnologyDecision_Relationship__c(
            Requesting_Domain__c = dom.Id,
            Requesting_Application__c = app.Id,
            Requesting_Technical_Architect__c = taEmp.Id,
            Requesting_Business_Owner__c = boEmp.Id,
            Requesting_Application_Owner__c = aoEmp.Id
        );
        insert rel;
        return rel;
    }

    private static Map<String, Object> buildDecisionFields() {
        Map<String, Object> m = new Map<String, Object>();
        m.put('Name', 'Unit Test Decision');
        m.put('Stage__c', 'Preparing Decision');
        m.put('Status__c', 'Draft');
        m.put('Decision_Reason__c', 'New Technology');
        m.put('Why__c', 'Why text');
        m.put('What__c', 'What text');
        m.put('Value__c', 'Value text');
        m.put('Description__c', 'Description text');
        m.put('Member_Value__c', 'Member value');
        m.put('Investment_Category__c', 'Run');
        m.put('Requestor__c', runAsEmp.Id);
        m.put('Requesting_Technical_Architect__c', taEmp.Id);
        m.put('Requesting_Business_Owner__c', boEmp.Id);
        m.put('Requesting_Application_Owner__c', aoEmp.Id);
        m.put('Requesting_Tech_Fellow__c', tfEmp.Id);
        m.put('Is_Create_Notification_Send__c', true);
        return m;
    }

    private static Map<String, Object> buildRelationFields() {
        TPM_Domain__c dom = createDomain();
        TPM_App__c app = createApp();

        Map<String, Object> m = new Map<String, Object>();
        m.put('Requesting_Domain__c', dom.Id);
        m.put('Requesting_Application__c', app.Id);
        m.put('Requesting_Technical_Architect__c', taEmp.Id);
        m.put('Requesting_Business_Owner__c', boEmp.Id);
        m.put('Requesting_Application_Owner__c', aoEmp.Id);
        return m;
    }

    private static TechnologyDecision__c createBaseDecision(String reason, String stage, String status) {
        TechnologyDecision_Relationship__c rel = createRelationship();

        TechnologyDecision__c dec = new TechnologyDecision__c(
            Name = 'Decision ' + System.now().getTime(),
            Stage__c = stage,
            Status__c = status,
            Decision_Reason__c = reason,
            Why__c = 'Why text',
            What__c = 'What text',
            Value__c = 'Value text',
            Description__c = 'Description text',
            Member_Value__c = 'Member value',
            Investment_Category__c = 'Run',
            TechnologyDecision_Relationship__c = rel.Id,
            Requestor__c = runAsEmp.Id,
            Requesting_Technical_Architect__c = taEmp.Id,
            Requesting_Business_Owner__c = boEmp.Id,
            Requesting_Application_Owner__c = aoEmp.Id,
            Requesting_Tech_Fellow__c = tfEmp.Id,
            Is_Create_Notification_Send__c = true,
            TA_Acknowledged__c = false,
            BO_Acknowledged__c = false,
            AO_Acknowledged__c = false,
            Security_Review_Acknowledged__c = false
        );
        insert dec;
        return dec;
    }

    @IsTest
    static void testCreateDecisionWithRelation_success() {
        System.runAs(runAsUserRec) {
            Test.startTest();
            String decisionIdString = technologyDecision_CreateFormHelper.createDecisionWithRelation(
                buildDecisionFields(),
                buildRelationFields()
            );
            Test.stopTest();

            System.assertNotEquals(null, decisionIdString);

            TechnologyDecision__c dec = [
                SELECT Id, TechnologyDecision_Relationship__c
                FROM TechnologyDecision__c
                WHERE Id = :decisionIdString
            ];
            System.assertNotEquals(null, dec.TechnologyDecision_Relationship__c);
        }
    }

    @IsTest
    static void testSubmitApproval_PreparingDecisionComment() {
        System.runAs(runAsUserRec) {
            TechnologyDecision__c dec = createBaseDecision('New Technology', 'Saved', 'Draft');

            Test.startTest();
            Boolean result = technologyDecision_CreateFormHelper.submitApprovalComments(
                dec.Id,
                'Prep comment',
                'Preparing Decision Comment',
                null
            );
            Test.stopTest();

            System.assertEquals(true, result);

            TechnologyDecision__c refreshed = [
                SELECT Stage__c
                FROM TechnologyDecision__c
                WHERE Id = :dec.Id
            ];
            System.assertEquals('Preparing Decision', refreshed.Stage__c);
        }
    }

    @IsTest
    static void testSubmitApproval_AcknowledgementComment() {
        System.runAs(runAsUserRec) {
            TechnologyDecision__c dec = createBaseDecision('New Technology', 'Saved', 'Draft');

            Test.startTest();
            Boolean ok = technologyDecision_CreateFormHelper.submitApprovalComments(
                dec.Id,
                'submit for ack',
                'Acknowledgement Comment',
                null
            );
            Test.stopTest();

            System.assertEquals(true, ok);

            TechnologyDecision__c afterRec = [
                SELECT Stage__c, TA_Acknowledged__c
                FROM TechnologyDecision__c
                WHERE Id = :dec.Id
            ];
            System.assertEquals(true, afterRec.TA_Acknowledged__c);
        }
    }

    @IsTest
    static void testSubmitApproval_ApproveComment() {
        System.runAs(runAsUserRec) {
            TechnologyDecision__c dec = createBaseDecision(
                'New Technology',
                'Pending Approval with Tech Fellow',
                'Acknowledge'
            );

            TechnologyDecision_Approval__c pending = new TechnologyDecision_Approval__c(
                Decision__c = dec.Id,
                Action_Date_Time__c = System.now().addMinutes(-1),
                Type__c = 'Pending Approval with Tech Fellow',
                Approved__c = true,
                Assigned_To__c = String.valueOf(tfEmp.Id)
            );
            insert pending;

            Test.startTest();
            Boolean ok = technologyDecision_CreateFormHelper.submitApprovalComments(
                dec.Id,
                'Approve comment',
                'Approve Comment',
                null
            );
            Test.stopTest();

            System.assertEquals(true, ok);

            TechnologyDecision__c afterRec = [
                SELECT Stage__c, Status__c
                FROM TechnologyDecision__c
                WHERE Id = :dec.Id
            ];
            System.assertEquals('Complete', afterRec.Stage__c);
            System.assertEquals('Approve', afterRec.Status__c);
        }
    }

    @IsTest
    static void testValidateRequiredFieldsOnDecision() {
        System.runAs(runAsUserRec) {
            TechnologyDecision__c dec1 = createBaseDecision('Replace Application', 'Preparing Decision', 'Draft');
            TechnologyDecision__c dec2 = createBaseDecision('Replace Application', 'Saved', 'Draft');
            TechnologyDecision__c dec3 = createBaseDecision('Replace Application', 'Pending Security Review', 'Draft');
            TechnologyDecision__c dec4 = createBaseDecision('Replace Application', 'Pending Initial Tech Decision Review', 'Draft');
            TechnologyDecision__c dec5 = createBaseDecision('Replace Application', 'Pending Arch Forum Review', 'Draft');
            TechnologyDecision__c dec6 = createBaseDecision('Replace Application', 'Pending Tech Decision Review', 'Draft');

            Test.startTest();
            String r1 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec1.Id);
            String r2 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec2.Id);
            String r3 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec3.Id);
            String r4 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec4.Id);
            String r5 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec5.Id);
            String r6 = technologyDecision_CreateFormHelper.validateRequiredFieldsOnDecision(dec6.Id);
            Test.stopTest();

            System.assertNotEquals(null, r1);
            System.assertNotEquals(null, r2);
            System.assertNotEquals(null, r3);
            System.assertNotEquals(null, r4);
            System.assertNotEquals(null, r5);
            System.assertNotEquals(null, r6);
        }
    }
}
