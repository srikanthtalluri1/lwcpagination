   loadRecords(isNextPage = false) {
    this.isLoading = true;
    this.errorMessage = '';

    getStackLayJunction({
        pageSize: Number(this.pageSize),
        lastCreatedDate: this.lastCreatedDate,
        lastRecordId: this.lastRecordId
    })
        .then((result) => {
            const returnedRows = result?.rows || [];

            this.rows = returnedRows.map((row) => ({
                ...row,
                id: row.Id,
                appName: row.appName || '',
                status: row.operationalStatus || '',
                paamManual: row.paamManual || '',
                paamDiscovered: row.paamDiscovered || '',
                manualStatus: row.manualStatus || '',
                discoveredStatus: row.discoveredStatus || ''
            }));

            this.hasMore = result?.hasMore === true;
            this.totalRecordCount = result?.totalRecords || 0;

            this.lastCreatedDate =
                result?.lastCreatedDate || null;

            this.lastRecordId =
                result?.lastRecordId || null;

            // Increase page only after Apex successfully returns data.
            if (isNextPage && returnedRows.length > 0) {
                this.page += 1;
            }
        })
        .catch((error) => {
            console.error('Error loading records:', error);

            this.errorMessage =
                error?.body?.message ||
                error?.message ||
                'Unable to load records.';
        })
        .finally(() => {
            this.isLoading = false;
        });
}

