import { LightningElement, track } from 'lwc';

const STACK_LAYERS = [
  { n: 'Snowflake', s: 'Preferred' },
  { n: 'NA', s: 'Not Applicable' },
  { n: 'Apache Airflow within Domino', s: 'Acceptable' },
  { n: 'Other Application Bundled Schedulers without ITGC', s: 'Acceptable' },
  { n: 'BMC Control-M', s: 'Preferred' },
  { n: 'Native OS Schedulers on Unix, Linux, or Win platforms', s: 'Acceptable' },
  { n: 'IBM Integrated Analytics System (IIAS)', s: 'Restricted' },
  { n: 'AWS DynamoDB', s: 'Preferred' },
  { n: 'AWS RDS Postgresql', s: 'Acceptable' },
  { n: 'Public Cloud - FaaS', s: 'Preferred' },
  { n: 'Public Cloud - Container', s: 'Preferred' },
  { n: 'Oracle WebLogic v12c', s: 'Deprecated' },
  { n: 'Apache Tomcat 8.0.x', s: 'Denied' },
  { n: 'JBoss EAP - 5.x', s: 'Denied' },
  { n: 'gRPC', s: 'Preferred' },
  { n: 'GraphQL', s: 'Preferred' },
  { n: 'SOAP 1.2', s: 'Acceptable' }
];

const APPLICATIONS = [
  { n: 'Bugcrowd Bug Bounty Platform', s: 'Production' },
  { n: 'eCommerce Deposits - Stop Check Payment', s: 'Production' },
  { n: 'Intezer Analyze', s: 'Production' },
  { n: 'Contact Center recording - APIs', s: 'Production' },
  { n: 'Personal Lines Quotes Aggregator', s: 'Production' },
  { n: 'IBM Personal Communications', s: 'Production' },
  { n: 'Credit Card Capture Income', s: 'Production' },
  { n: 'Credit Card Storefront', s: 'Production' },
  { n: 'Cobalt Strike Adversary Simulation Software', s: 'Production' },
  { n: 'USAA Labs Reporting and Analytics Environment', s: 'Production' },
  { n: 'Consumer Lending Pricing', s: 'Production' },
  { n: 'File Transfer Activity Manager', s: 'Production' },
  { n: 'ServiceNow - Regulatory Change Management', s: 'Production' },
  { n: 'API Authorizer for AWS', s: 'Production' },
  { n: 'Risk Board of Directors Automation', s: 'Production' },
  { n: 'Cloud Reference Apps (AWS and GCP)', s: 'Production' },
  { n: 'Mobile App Review Analysis Tool - AppBot', s: 'Production' },
  { n: 'Salesforce - Enterprise Licensing Consolidation', s: 'Production' },
  { n: 'Salesforce Dataloader', s: 'Production' },
  { n: 'Copado', s: 'Production' },
  { n: 'Visual Studio Code', s: 'Production' },
  { n: 'ServiceNow - Change Management', s: 'Production' },
  { n: 'Slack', s: 'Production' },
  { n: 'Enterprise Architecture Standards', s: 'In Development' },
  { n: 'Pathfinder', s: 'In Development' },
  { n: 'Claims Contact Analytics', s: 'Sunsetting' },
  { n: 'Bank Offers', s: 'Sunsetting' }
];

const PAAM_ATTRIBUTES = ['Confidentiality', 'Integrity', 'Availability', 'Data Classification'];
const STACK_STATUS_OPTIONS = [
  { label: 'Preferred', slug: 'preferred' },
  { label: 'Acceptable', slug: 'acceptable' },
  { label: 'Under Consideration', slug: 'under-consideration' },
  { label: 'Restricted', slug: 'restricted' },
  { label: 'Deprecated', slug: 'deprecated' },
  { label: 'Denied', slug: 'denied' },
  { label: 'Not Applicable', slug: 'not-applicable' }
];

function hash(str) {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < str.length; i += 1) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619) >>> 0;
  }
  return h;
}

function statusSlug(status) {
  return (status || 'unknown')
    .toString()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '') || 'unknown';
}

function formatNumber(value) {
  return Number(value || 0).toLocaleString();
}

const PAAM_VALUES = STACK_LAYERS.map((s) => s.n);
const STACK_STATUS = new Map(STACK_LAYERS.map((s) => [s.n, s.s || 'Unknown']));

function paamFor(seed) {
  return PAAM_VALUES[hash(seed) % PAAM_VALUES.length];
}

function buildRecords(apps) {
  const out = [];
  let idCounter = 1;

  apps.forEach((app) => {
    const appName = app.n || 'Unknown';
    const status = app.s || 'Unknown';

    const ownerBucket = hash('owner::' + appName) % 100;
    const isMine = ownerBucket < 40;        // sample UI: more visible rows
    const isPrimary = isMine && (hash('primary::' + appName) % 2 === 0);

    PAAM_ATTRIBUTES.forEach((attr) => {
      const manual = paamFor('manual::' + appName + '::' + attr);
      const conflictBucket = hash('conflict::' + appName + '::' + attr) % 10;
      let discovered = manual;

      if (conflictBucket < 3) {
        const other = PAAM_VALUES.filter((v) => v !== manual);
        discovered = other[conflictBucket % other.length];
      }

      out.push({
        id: String(idCounter++),
        appName,
        status,
        attribute: attr,
        paamManual: manual,
        paamDiscovered: discovered,
        isMine,
        isPrimary
      });
    });
  });

  return out;
}

export default class PaamConflicts extends LightningElement {
  @track rows = buildRecords(APPLICATIONS);
  @track overrides = {};

  query = '';
  view = 'conflicts';        // conflicts | all | sync
  scope = 'primary';         // primary | mine | all
  statusFilter = 'all';
  sortField = 'appName';
  sortDir = 'asc';
  page = 1;
  pageSize = 100;

  toastMessage = '';
  toastKind = 'success';

  stackStatusOptions = STACK_STATUS_OPTIONS;

  get isPrimaryScope() {
    return this.scope === 'primary';
  }

  get primaryScopeClass() {
    return this.scope === 'primary' ? 'is-active' : '';
  }

  get mineScopeClass() {
    return this.scope === 'mine' ? 'is-active' : '';
  }

  get allScopeClass() {
    return this.scope === 'all' ? 'is-active' : '';
  }

  get conflictsViewClass() {
    return this.view === 'conflicts' ? 'is-active' : '';
  }

  get allViewClass() {
    return this.view === 'all' ? 'is-active' : '';
  }

  get syncViewClass() {
    return this.view === 'sync' ? 'is-active' : '';
  }

  get totalApps() {
    return new Set(this.rows.map((r) => r.appName)).size;
  }

  get totalRecords() {
    return this.rows.length;
  }

  get totalConflicts() {
    return this.rows.filter((r) => r.paamManual !== r.paamDiscovered).length;
  }

  get totalSync() {
    return this.totalRecords - this.totalConflicts;
  }

  get conflictPct() {
    return this.totalRecords ? Math.round((this.totalConflicts / this.totalRecords) * 100) : 0;
  }

  get totalAppsDisplay() {
    return formatNumber(this.totalApps);
  }

  get totalRecordsDisplay() {
    return formatNumber(this.totalRecords);
  }

  get totalConflictsDisplay() {
    return formatNumber(this.totalConflicts);
  }

  get totalSyncDisplay() {
    return formatNumber(this.totalSync);
  }

  get filteredRowsRaw() {
    let out = this.rows.map((r) => ({
      ...r,
      isConflict: r.paamManual !== r.paamDiscovered
    }));

    if (this.scope === 'mine') {
      out = out.filter((r) => r.isMine);
    } else if (this.scope === 'primary') {
      out = out.filter((r) => r.isPrimary);
    }

    if (this.view === 'conflicts') {
      out = out.filter((r) => r.isConflict);
    } else if (this.view === 'sync') {
      out = out.filter((r) => !r.isConflict);
    }

    if (this.statusFilter !== 'all') {
      out = out.filter((r) => {
        const manualStatus = statusSlug(STACK_STATUS.get(r.paamManual) || 'Unknown');
        const discoveredStatus = statusSlug(STACK_STATUS.get(r.paamDiscovered) || 'Unknown');
        return manualStatus === this.statusFilter || discoveredStatus === this.statusFilter;
      });
    }

    if (this.query.trim()) {
      const q = this.query.trim().toLowerCase();
      out = out.filter((r) =>
        r.appName.toLowerCase().includes(q) ||
        (r.status || '').toLowerCase().includes(q) ||
        (r.attribute || '').toLowerCase().includes(q) ||
        r.paamManual.toLowerCase().includes(q) ||
        r.paamDiscovered.toLowerCase().includes(q)
      );
    }

    out.sort((a, b) => {
      if (a.appName !== b.appName && this.sortField !== 'appName') {
        return a.appName.toLowerCase() < b.appName.toLowerCase() ? -1 : 1;
      }

      const va = String(a[this.sortField] ?? '').toLowerCase();
      const vb = String(b[this.sortField] ?? '').toLowerCase();

      if (va < vb) return this.sortDir === 'asc' ? -1 : 1;
      if (va > vb) return this.sortDir === 'asc' ? 1 : -1;
      return 0;
    });

    return out;
  }

  get filteredCountDisplay() {
    return formatNumber(this.filteredRowsRaw.length);
  }

  get totalPages() {
    return Math.max(1, Math.ceil(this.filteredRowsRaw.length / Number(this.pageSize)));
  }

  get currentPage() {
    return Math.min(this.page, this.totalPages);
  }

  get pageStart() {
    return (this.currentPage - 1) * Number(this.pageSize);
  }

  get pageRows() {
    return this.filteredRowsRaw
      .slice(this.pageStart, this.pageStart + Number(this.pageSize))
      .map((row) => {
        const manualStatus = STACK_STATUS.get(row.paamManual) || 'Unknown';
        const discoveredStatus = STACK_STATUS.get(row.paamDiscovered) || 'Unknown';
        const manualSlug = statusSlug(manualStatus);
        const discoveredSlug = statusSlug(discoveredStatus);
        const wasOverridden = this.overrides[row.id] !== undefined;

        return {
          ...row,
          rowClass: (row.isConflict ? 'paam-row-conflict ' : '') + 'paam-row-group-start',
          manualPillClass: `paam-pill paam-pill--${manualSlug} ${row.isConflict ? 'paam-pill--diff' : ''}`,
          discoveredPillClass: `paam-pill paam-pill--${discoveredSlug} ${row.isConflict ? 'paam-pill--diff' : ''}`,
          manualTitle: `${row.paamManual} — ${manualStatus}`,
          discoveredTitle: `${row.paamDiscovered} — ${discoveredStatus}`,
          diffTitle: `Will change to ${row.paamDiscovered}`,
          syncStatusClass: row.isConflict ? 'paam-status paam-status--conflict' : 'paam-status paam-status--sync',
          syncStatusLabel: row.isConflict ? 'Conflict' : 'In Sync',
          acceptTitle: `Replace PAAM Manual (${row.paamManual}) with PAAM Discovered (${row.paamDiscovered})`,
          wasOverridden
        };
      });
  }

  get hasPageRows() {
    return this.pageRows.length > 0;
  }

  get emptyColspan() {
    return this.isPrimaryScope ? 6 : 5;
  }

  get isFirstPage() {
    return this.currentPage === 1;
  }

  get isLastPage() {
    return this.currentPage === this.totalPages;
  }

  get footerRangeLabel() {
    const filteredLength = this.filteredRowsRaw.length;
    if (filteredLength === 0) return '0 results';

    const start = this.pageStart + 1;
    const end = Math.min(this.pageStart + Number(this.pageSize), filteredLength);
    return `Showing ${formatNumber(start)}–${formatNumber(end)} of ${formatNumber(filteredLength)}`;
  }

  get appSortArrow() {
    return this.getSortArrow('appName');
  }

  get statusSortArrow() {
    return this.getSortArrow('status');
  }

  get manualSortArrow() {
    return this.getSortArrow('paamManual');
  }

  get discoveredSortArrow() {
    return this.getSortArrow('paamDiscovered');
  }

  get toastClass() {
    return `paam-toast paam-toast--${this.toastKind}`;
  }

  getSortArrow(field) {
    if (this.sortField !== field) return '↕';
    return this.sortDir === 'asc' ? '↑' : '↓';
  }

  resetPage() {
    this.page = 1;
  }

  handleSearch(event) {
    this.query = event.target.value;
    this.resetPage();
  }

  handleScopeChange(event) {
    this.scope = event.currentTarget.dataset.scope;
    this.resetPage();
  }

  handleViewChange(event) {
    this.view = event.currentTarget.dataset.view;
    this.resetPage();
  }

  handleStatusFilterChange(event) {
    this.statusFilter = event.target.value;
    this.resetPage();
  }

  handleSort(event) {
    const field = event.currentTarget.dataset.field;

    if (this.sortField === field) {
      this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      this.sortField = field;
      this.sortDir = 'asc';
    }

    this.resetPage();
  }

  handleAccept(event) {
    const id = event.currentTarget.dataset.id;
    const row = this.rows.find((r) => r.id === id);

    if (!row || row.paamManual === row.paamDiscovered) return;

    const originalManual = row.paamManual;

    this.rows = this.rows.map((r) =>
      r.id === id ? { ...r, paamManual: row.paamDiscovered } : r
    );

    this.overrides = {
      ...this.overrides,
      [id]: originalManual
    };

    this.showToast('success', `Accepted “${row.paamDiscovered}” for ${row.appName} · ${row.attribute}`);
  }

  handleUndo(event) {
    const id = event.currentTarget.dataset.id;
    const original = this.overrides[id];

    if (original === undefined) return;

    this.rows = this.rows.map((r) =>
      r.id === id ? { ...r, paamManual: original } : r
    );

    const nextOverrides = { ...this.overrides };
    delete nextOverrides[id];
    this.overrides = nextOverrides;

    this.showToast('success', `Reverted to “${original}”`);
  }

  handlePageSizeChange(event) {
    this.pageSize = Number(event.target.value);
    this.resetPage();
  }

  goFirst() {
    this.page = 1;
  }

  goPrev() {
    this.page = Math.max(1, this.page - 1);
  }

  goNext() {
    this.page = Math.min(this.totalPages, this.page + 1);
  }

  goLast() {
    this.page = this.totalPages;
  }

  showToast(kind, message) {
    this.toastKind = kind;
    this.toastMessage = message;

    window.clearTimeout(this.toastTimeout);
    this.toastTimeout = window.setTimeout(() => {
      this.toastMessage = '';
    }, 3500);
  }

  dismissToast() {
    this.toastMessage = '';
  }
}


:host {
  /* USAA brand palette */
  --paam-bg-start: #eef3f7;
  --paam-bg-end: #f7f3ea;
  --paam-card-bg: #ffffff;
  --paam-border: #d9e0e6;
  --paam-text: #0d2436;
  --paam-muted: #5b6b78;

  --paam-primary: #003B5C;
  --paam-primary-soft: #e5edf3;
  --paam-primary-dark: #002855;

  --paam-gold: #C2A77E;
  --paam-gold-dark: #a78a5e;

  --paam-danger: #B3261E;
  --paam-danger-soft: #fbeae8;
  --paam-success: #1f7a4d;
  --paam-success-soft: #e6f2ec;

  --paam-shadow: 0 10px 30px -12px rgba(0, 40, 85, 0.22),
    0 2px 6px -2px rgba(0, 40, 85, 0.08);

  display: block;
  color: var(--paam-text);
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.paam-page {
  padding: 2.5rem 1.5rem 3rem;
  max-width: 1200px;
  margin: 0 auto;
  background:
    radial-gradient(1200px 600px at 0% -10%, #d6e2eb 0%, transparent 60%),
    radial-gradient(900px 500px at 100% 0%, #efe6d2 0%, transparent 55%),
    linear-gradient(180deg, var(--paam-bg-start) 0%, var(--paam-bg-end) 100%);
  min-height: 100vh;
}

/* Hero */
.paam-hero {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
  padding: 1.75rem 1.75rem 1.5rem;
  flex-wrap: wrap;
  background:
    linear-gradient(135deg, var(--paam-primary-dark) 0%, var(--paam-primary) 55%, #0a4d72 100%);
  border-radius: 14px;
  border: 1px solid var(--paam-primary-dark);
  box-shadow: 0 14px 32px -16px rgba(0, 40, 85, 0.55);
  overflow: hidden;
}

.paam-hero::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5px;
  background: linear-gradient(180deg, var(--paam-gold) 0%, var(--paam-gold-dark) 100%);
}

.paam-hero::after {
  content: "";
  position: absolute;
  right: -80px;
  top: -80px;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(194, 167, 126, 0.22) 0%, rgba(194, 167, 126, 0) 70%);
  pointer-events: none;
}

.paam-hero > * {
  position: relative;
  z-index: 1;
}

.paam-hero h1 {
  margin: 0;
  font-size: 1.9rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #ffffff;
}

.paam-hero h1 .paam-hero__accent {
  color: var(--paam-gold);
}

.paam-hero p {
  margin: 0.35rem 0 0;
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.95rem;
}

.paam-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.3rem 0.7rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--paam-gold);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(194, 167, 126, 0.45);
  border-radius: 999px;
  margin-bottom: 0.75rem;
  backdrop-filter: blur(2px);
}

.paam-eyebrow::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--paam-gold);
  box-shadow: 0 0 0 3px rgba(194, 167, 126, 0.25);
}

/* Stat cards */
.paam-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 1.25rem;
}

.paam-stat {
  background: var(--paam-card-bg);
  border: 1px solid var(--paam-border);
  border-radius: 14px;
  padding: 1rem 1.1rem;
  box-shadow: var(--paam-shadow);
  position: relative;
  overflow: hidden;
}

.paam-stat__accent {
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
}

.paam-stat--total .paam-stat__accent {
  background: var(--paam-primary);
}

.paam-stat--conflict .paam-stat__accent {
  background: var(--paam-danger);
}

.paam-stat--sync .paam-stat__accent {
  background: var(--paam-success);
}

.paam-stat__label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--paam-muted);
}

.paam-stat__value {
  font-size: 1.85rem;
  font-weight: 700;
  line-height: 1.1;
  margin-top: 0.25rem;
  letter-spacing: -0.02em;
}

.paam-stat__hint {
  margin-top: 0.25rem;
  font-size: 0.78rem;
  color: var(--paam-muted);
}

.paam-stat--conflict .paam-stat__value {
  color: var(--paam-danger);
}

.paam-stat--sync .paam-stat__value {
  color: var(--paam-success);
}

/* Card */
.paam-card {
  background: var(--paam-card-bg);
  border: 1px solid var(--paam-border);
  border-radius: 16px;
  box-shadow: var(--paam-shadow);
  overflow: hidden;
}

.paam-card__header {
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--paam-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  background: linear-gradient(180deg, #f6f8fa 0%, #ffffff 100%);
}

.paam-card__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
}

.paam-card__subtitle {
  font-size: 0.82rem;
  color: var(--paam-muted);
  margin: 0.1rem 0 0;
}

/* Toolbar */
.paam-toolbar {
  display: flex;
  gap: 0.75rem;
  align-items: flex-end;
  flex-wrap: wrap;
}

.paam-field {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.paam-field__label {
  font-size: 0.72rem;
  font-weight: 400;
  color: #444;
  letter-spacing: 0;
}

/* Search input */
.paam-search {
  position: relative;
}

.paam-search input {
  width: 260px;
  max-width: 100%;
  height: 1.875rem;
  padding: 0 0.75rem 0 2rem;
  font: inherit;
  font-size: 0.8125rem;
  line-height: 1.875rem;
  border: 1px solid #aeaeae;
  border-radius: 0.25rem;
  background: #fff;
  color: #181818;
  transition: border-color 0.1s linear, box-shadow 0.1s linear;
  outline: none;
}

.paam-search input::placeholder {
  color: #706e6b;
}

.paam-search input:focus {
  border-color: #1b96ff;
  box-shadow: 0 0 3px #0176d3;
}

.paam-search svg {
  position: absolute;
  left: 0.55rem;
  top: 50%;
  transform: translateY(-50%);
  width: 14px;
  height: 14px;
  color: #706e6b;
  pointer-events: none;
}

/* Picklist */
.paam-select {
  font: inherit;
  font-size: 0.8125rem;
  height: 1.875rem;
  padding: 0 1.75rem 0 0.75rem;
  border: 1px solid #aeaeae;
  border-radius: 0.25rem;
  background: #fff;
  color: #181818;
  cursor: pointer;
  outline: none;
  appearance: none;
  transition: border-color 0.1s linear, box-shadow 0.1s linear;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path fill='%23706e6b' d='M0 0l5 6 5-6z'/></svg>");
  background-repeat: no-repeat;
  background-position: right 0.6rem center;
}

.paam-select:focus {
  border-color: #1b96ff;
  box-shadow: 0 0 3px #0176d3;
}

/* Segmented control */
.paam-segmented {
  display: inline-flex;
  height: 1.875rem;
  border-radius: 0.25rem;
  overflow: hidden;
  background: #fff;
}

.paam-segmented button {
  appearance: none;
  background: #fff;
  border: 1px solid #aeaeae;
  border-right-width: 0;
  font: inherit;
  font-size: 0.8125rem;
  font-weight: 400;
  color: #0176d3;
  padding: 0 0.85rem;
  height: 1.875rem;
  line-height: 1;
  cursor: pointer;
  transition: background 0.1s linear, color 0.1s linear, box-shadow 0.1s linear;
  white-space: nowrap;
}

.paam-segmented button:first-child {
  border-top-left-radius: 0.25rem;
  border-bottom-left-radius: 0.25rem;
}

.paam-segmented button:last-child {
  border-right-width: 1px;
  border-top-right-radius: 0.25rem;
  border-bottom-right-radius: 0.25rem;
}

.paam-segmented button:hover {
  background: #f3f3f3;
}

.paam-segmented button:focus {
  outline: none;
  box-shadow: 0 0 3px #0176d3;
  position: relative;
  z-index: 1;
}

.paam-segmented button.is-active {
  background: #0176d3;
  border-color: #014486;
  color: #fff;
}

.paam-segmented button.is-active:hover {
  background: #014486;
}

/* Table */
.paam-table-wrap {
  overflow-x: auto;
}

.paam-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.92rem;
}

.paam-table thead th {
  background: #f8fafc;
  color: var(--paam-muted);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 600;
  text-align: left;
  padding: 0.7rem 1rem;
  border-bottom: 1px solid var(--paam-border);
  position: sticky;
  top: 0;
  user-select: none;
}

.paam-table thead th button {
  background: none;
  border: 0;
  padding: 0;
  font: inherit;
  color: inherit;
  text-transform: inherit;
  letter-spacing: inherit;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}

.paam-table thead th button:hover {
  color: var(--paam-text);
}

.paam-action-heading {
  text-align: right !important;
}

.paam-table tbody td,
.paam-table tbody th {
  padding: 0.85rem 1rem;
  border-bottom: 1px solid #f1f5f9;
  vertical-align: middle;
  font-weight: 400;
}

.paam-table tbody tr:last-child td,
.paam-table tbody tr:last-child th {
  border-bottom: 0;
}

.paam-table tbody tr:hover {
  background-color: #f4f7fa;
}

.paam-row-conflict {
  background-color: rgba(220, 38, 38, 0.04);
}

.paam-row-conflict:hover {
  background-color: rgba(220, 38, 38, 0.08);
}

.paam-row-group-start td,
.paam-row-group-start th {
  border-top: 2px solid #e2e8f0;
}

.paam-attr {
  font-weight: 500;
  color: #334155;
}

.paam-app-cell {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  text-align: left;
}

.paam-table th[scope="row"],
.paam-table td {
  text-align: left;
}

.paam-app-name {
  font-weight: 500;
  color: var(--paam-text);
}

/* PAAM pill */
.paam-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
  border: 1px solid transparent;
  background: #f1f5f9;
  color: #334155;
  max-width: 280px;
  white-space: normal;
  line-height: 1.25;
  text-align: left;
}

.paam-pill--preferred {
  background: #e6f4ea;
  color: #1f7a3a;
  border-color: #b7dcc3;
}

.paam-pill--acceptable {
  background: var(--paam-primary-soft);
  color: var(--paam-primary);
  border-color: #b8c8d6;
}

.paam-pill--restricted {
  background: #fef3c7;
  color: #92400e;
  border-color: #f3d98a;
}

.paam-pill--deprecated {
  background: #ffedd5;
  color: #c2410c;
  border-color: #f5c79a;
}

.paam-pill--denied {
  background: #fee2e2;
  color: #b91c1c;
  border-color: #f5b5b5;
}

.paam-pill--not-applicable {
  background: #eef1f3;
  color: #4a5b69;
  border-color: #d9e0e6;
}

.paam-pill--under-consideration {
  background: #e0f2fe;
  color: #075985;
  border-color: #b6dcf2;
}

.paam-pill--unknown {
  background: #f1f5f9;
  color: #334155;
  border-color: #cbd5e1;
}

.paam-pill--diff {
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.08);
}

.paam-pill__label {
  min-width: 0;
}

/* Sync status */
.paam-status {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
}

.paam-status::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.paam-status--sync {
  background: var(--paam-success-soft);
  color: var(--paam-success);
}

.paam-status--sync::before {
  background: var(--paam-success);
}

.paam-status--conflict {
  background: var(--paam-danger-soft);
  color: var(--paam-danger);
}

.paam-status--conflict::before {
  background: var(--paam-danger);
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.15);
}

.paam-empty {
  padding: 3rem 1rem;
  text-align: center !important;
  color: var(--paam-muted);
}

.paam-empty__icon {
  font-size: 2rem;
  opacity: 0.5;
}

/* Buttons */
.paam-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  appearance: none;
  font: inherit;
  font-size: 0.8rem;
  font-weight: 500;
  padding: 0.4rem 0.7rem;
  border-radius: 8px;
  border: 1px solid var(--paam-border);
  background: #fff;
  color: var(--paam-text);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.paam-btn:hover {
  border-color: #cbd5e1;
  background: #f8fafc;
}

.paam-btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(0, 59, 92, 0.2);
  border-color: var(--paam-primary);
}

.paam-btn[disabled] {
  opacity: 0.5;
  cursor: not-allowed;
}

.paam-overridden {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--paam-success);
  margin-top: 0.2rem;
}

.paam-diff-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 24px;
  color: var(--paam-danger);
  opacity: 0.8;
}

.paam-diff-cell {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.paam-btn--accept {
  background: var(--paam-success);
  border-color: var(--paam-success);
  color: #fff;
  padding: 0.4rem 0.85rem;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  border-radius: 999px;
  box-shadow: 0 1px 2px rgba(5, 150, 105, 0.18);
}

.paam-btn--accept:hover {
  background: #047857;
  border-color: #047857;
  box-shadow: 0 2px 6px rgba(5, 150, 105, 0.28);
}

.paam-btn--accept svg {
  width: 14px;
  height: 14px;
}

.paam-action-cell {
  text-align: right !important;
}

.paam-action-stack {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  justify-content: flex-end;
}

.paam-action-undo {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--paam-muted);
  background: #fff;
  border: 1px solid var(--paam-border);
  border-radius: 999px;
  padding: 0.2rem 0.6rem;
  cursor: pointer;
  transition: all 0.15s ease;
}

.paam-action-undo:hover {
  color: var(--paam-text);
  background: #f8fafc;
}

.paam-accepted-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--paam-success);
  background: #e6f4ea;
  border: 1px solid #b7dcc3;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
}

.paam-accepted-tag svg {
  width: 12px;
  height: 12px;
}

.paam-action-empty {
  color: var(--paam-muted);
  font-size: 0.9rem;
}

/* Toast */
.paam-toast-region {
  position: fixed;
  bottom: 1.25rem;
  right: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  z-index: 9999;
  pointer-events: none;
}

.paam-toast {
  pointer-events: auto;
  min-width: 260px;
  max-width: 380px;
  padding: 0.65rem 0.9rem;
  border-radius: 10px;
  font-size: 0.85rem;
  color: #fff;
  background: #0f172a;
  box-shadow: 0 6px 20px rgba(15, 23, 42, 0.22);
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  animation: paam-toast-in 0.18s ease-out;
}

.paam-toast--success {
  background: #047857;
}

.paam-toast--error {
  background: #b91c1c;
}

.paam-toast__close {
  background: transparent;
  border: 0;
  color: inherit;
  opacity: 0.75;
  cursor: pointer;
  font-size: 1rem;
  line-height: 1;
  margin-left: auto;
  padding: 0;
}

.paam-toast__close:hover {
  opacity: 1;
}

@keyframes paam-toast-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Footer */
.paam-card__footer {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--paam-border);
  font-size: 0.82rem;
  color: var(--paam-muted);
  background: #f6f8fa;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.paam-pager {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.paam-page-size-label {
  font-size: 0.8rem;
  color: var(--paam-muted);
}

.paam-page-size {
  font: inherit;
  font-size: 0.8rem;
  padding: 0.2rem 0.4rem;
  border: 1px solid var(--paam-border);
  border-radius: 6px;
  background: #fff;
}

.paam-page-label {
  font-size: 0.82rem;
}

@media (max-width: 900px) {
  .paam-page {
    padding: 1rem;
  }

  .paam-toolbar {
    width: 100%;
  }

  .paam-search input {
    width: 100%;
  }

  .paam-field {
    width: 100%;
  }

  .paam-segmented {
    width: 100%;
  }

  .paam-segmented button {
    flex: 1;
  }
}
