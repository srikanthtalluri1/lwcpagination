mport { LightningElement, api, wire } from 'lwc';
import { getRecord, getFieldValue, getFieldDisplayValue } from 'lightning/uiRecordApi';

import STATUS_FIELD from '@salesforce/schema/TechnologyDecision__c.Status__c';
import STAGE_FIELD  from '@salesforce/schema/TechnologyDecision__c.Stage__c';

const FIELDS = [STATUS_FIELD, STAGE_FIELD];

export default class MyComp extends LightningElement {
  @api recordId;

  @wire(getRecord, { recordId: '$recordId', fields: FIELDS })
  wiredRecord({ data, error }) {
    if (data) {
      const status = getFieldValue(data, STATUS_FIELD);
      const stage  = getFieldDisplayValue(data, STAGE_FIELD) ?? getFieldValue(data, STAGE_FIELD);

      // use them safely
      console.log(status, stage);
    } else if (error) {
      console.error(error);
    }
  }
}
