  renderedCallback() {
    const pageSizeSelect = this.template.querySelector('.paam-page-size');

    if (pageSizeSelect && pageSizeSelect.value !== String(this.pageSize)) {
        pageSizeSelect.value = String(this.pageSize);
    }
