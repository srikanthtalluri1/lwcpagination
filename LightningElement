@IsTest
private class POCUITest {

    private static final String PRIMARY_ACTIVE_APP =
        'Primary Active Application';

    private static final String DELEGATE_ACTIVE_APP =
        'Delegate Active Application';

    private static final String UNOWNED_ACTIVE_APP =
        'Unowned Active Application';

    private static final String INACTIVE_PRIMARY_APP =
        'Inactive Primary Application';


    @TestSetup
    static void createTestData() {

        /*
         * Active app where the current user is a
         * primary owner.
         */
        Id primaryAppId = createApp(
            PRIMARY_ACTIVE_APP,
            false,
            'IT_Architect__c'
        );

        /*
         * Active app where the current user is a
         * delegate owner.
         */
        Id delegateAppId = createApp(
            DELEGATE_ACTIVE_APP,
            false,
            'IT_Architect_Delegate_1__c'
        );

        /*
         * Active app that is not owned by the current user.
         */
        Id unownedAppId = createApp(
            UNOWNED_ACTIVE_APP,
            false,
            null
        );

        /*
         * Inactive app owned by the current user.
         * This record must never be returned.
         */
        Id inactiveAppId = createApp(
            INACTIVE_PRIMARY_APP,
            true,
            'IT_Architect__c'
        );

        Id primaryAppStackId = createAppStack(
            primaryAppId,
            'Primary Application Stack'
        );

        Id delegateAppStackId = createAppStack(
            delegateAppId,
            'Delegate Application Stack'
        );

        Id unownedAppStackId = createAppStack(
            unownedAppId,
            'Unowned Application Stack'
        );

        Id inactiveAppStackId = createAppStack(
            inactiveAppId,
            'Inactive Application Stack'
        );

        Id primaryConfigId = createStackLayerConfig(
            'Primary Manual Layer'
        );

        Id delegateConfigId = createStackLayerConfig(
            'Delegate Manual Layer'
        );

        Id unownedConfigId = createStackLayerConfig(
            'Unowned Manual Layer'
        );

        Id inactiveConfigId = createStackLayerConfig(
            'Inactive Manual Layer'
        );

        TPM_Stack_Layer_Junction__c primaryJunction =
            createJunction(
                primaryAppStackId,
                primaryConfigId
            );

        TPM_Stack_Layer_Junction__c delegateJunction =
            createJunction(
                delegateAppStackId,
                delegateConfigId
            );

        TPM_Stack_Layer_Junction__c unownedJunction =
            createJunction(
                unownedAppStackId,
                unownedConfigId
            );

        TPM_Stack_Layer_Junction__c inactiveJunction =
            createJunction(
                inactiveAppStackId,
                inactiveConfigId
            );

        /*
         * Set different CreatedDate values so pagination
         * order can be tested reliably.
         *
         * Newest:
         * 1. Inactive record — must be excluded
         * 2. Unowned active record
         * 3. Delegate active record
         * 4. Primary active record
         */
        Datetime currentTime = System.now();

        Test.setCreatedDate(
            inactiveJunction.Id,
            currentTime.addDays(-1)
        );

        Test.setCreatedDate(
            unownedJunction.Id,
            currentTime.addDays(-2)
        );

        Test.setCreatedDate(
            delegateJunction.Id,
            currentTime.addDays(-3)
        );

        Test.setCreatedDate(
            primaryJunction.Id,
            currentTime.addDays(-4)
        );
    }


    @IsTest
    static void testAllReturnsOnlyActiveApps() {

        Test.startTest();

        POCUI.PaamPageResult result =
            POCUI.getStackLayJunction(
                null,
                null,
                null,
                'All',
                null
            );

        Test.stopTest();

        System.assertEquals(
            3,
            result.totalRecords,
            'Only the three active applications should be counted.'
        );

        System.assertEquals(
            3,
            result.rows.size(),
            'Only active application records should be returned.'
        );

        System.assertEquals(
            false,
            result.hasMore,
            'There should not be another page.'
        );

        Set<String> returnedAppNames =
            getReturnedAppNames(result.rows);

        System.assert(
            returnedAppNames.contains(PRIMARY_ACTIVE_APP),
            'Primary active application should be returned.'
        );

        System.assert(
            returnedAppNames.contains(DELEGATE_ACTIVE_APP),
            'Delegate active application should be returned.'
        );

        System.assert(
            returnedAppNames.contains(UNOWNED_ACTIVE_APP),
            'Unowned active application should be returned.'
        );

        System.assert(
            !returnedAppNames.contains(INACTIVE_PRIMARY_APP),
            'Inactive application must not be returned.'
        );
    }


    @IsTest
    static void testMyPrimaryOwnershipFilter() {

        Test.startTest();

        POCUI.PaamPageResult result =
            POCUI.getStackLayJunction(
                50,
                null,
                null,
                'MyPrimary',
                null
            );

        Test.stopTest();

        System.assertEquals(
            1,
            result.totalRecords,
            'MyPrimary should return only active apps where the user is a primary owner.'
        );

        System.assertEquals(
            1,
            result.rows.size()
        );

        System.assertEquals(
            PRIMARY_ACTIVE_APP,
            result.rows[0].appName
        );

        System.assertNotEquals(
            INACTIVE_PRIMARY_APP,
            result.rows[0].appName,
            'Inactive primary-owned app must not be returned.'
        );
    }


    @IsTest
