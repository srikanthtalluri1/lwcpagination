import { LightningElement, track } from 'lwc';
import getStackLayJunction from '@salesforce/apex/POCUI.getStackLayJunction';

const STACK_STATUS_OPTIONS = [
    { label: 'Preferred', slug: 'preferred' },
    { label: 'Acceptable', slug: 'acceptable' },
    {
        label: 'Under Consideration',
        slug: 'under-consideration'
    },
    { label: 'Restricted', slug: 'restricted' },
    { label: 'Deprecated', slug: 'deprecated' },
    { label: 'Denied', slug: 'denied' },
    { label: 'Not Applicable', slug: 'not-applicable' }
];

function statusSlug(status) {
    return (status || 'unknown')
        .toString()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '') || 'unknown';
}

function formatNumber(value) {
    return Number(value || 0).toLocaleString();
}

export default class PaamConflicts extends LightningElement {
    @track overrides = {};
    @track rows = [];
    @track isLoading = false;
    @track errorMessage = '';

    lastCreatedDate = null;
    lastRecordId = null;
    hasMore = true;
    totalRecordCount = 0;

    page = 1;
    pageSize = 50;

    query = '';
    view = 'conflicts';
    scope = 'primary';
    statusFilter = 'all';

    sortField = 'appName';
    sortDir = 'asc';

    toastMessage = '';
    toastKind = 'success';

    searchTimeout;
    toastTimeout;

    stackStatusOptions = STACK_STATUS_OPTIONS;

    connectedCallback() {
        this.loadRecords();
    }

    renderedCallback() {
        const pageSizeSelect =
            this.template.querySelector('.paam-page-size');

        if (
            pageSizeSelect &&
            pageSizeSelect.value !== String(this.pageSize)
        ) {
            pageSizeSelect.value = String(this.pageSize);
        }
    }

    get ownedBy() {
        if (this.scope === 'primary') {
            return 'MyPrimary';
        }

        if (this.scope === 'mine') {
            return 'MyAll';
        }

        return 'All';
    }

    loadRecords(isNextPage = false) {
        this.isLoading = true;
        this.errorMessage = '';

        getStackLayJunction({
            pageSize: Number(this.pageSize),
            lastCreatedDate: this.lastCreatedDate,
            lastRecordId: this.lastRecordId,
            ownedBy: this.ownedBy,
            searchKey: this.query
        })
            .then((result) => {
                const returnedRows = result?.rows || [];

                this.rows = returnedRows.map((row) => ({
                    ...row,
                    id: row.Id,
                    appId:
                        row.appId ||
                        row.appName ||
                        row.Id,
                    appName: row.appName || '',
                    status: row.operationalStatus || '',
                    paamManual: row.paamManual || '',
                    paamDiscovered:
                        row.paamDiscovered || '',
                    manualStatus: row.manualStatus || '',
                    discoveredStatus:
                        row.discoveredStatus || ''
                }));

                this.hasMore =
                    result?.hasMore === true;

                this.totalRecordCount =
                    result?.totalRecords || 0;

                this.lastCreatedDate =
                    result?.lastCreatedDate || null;

                this.lastRecordId =
                    result?.lastRecordId || null;

                if (
                    isNextPage &&
                    returnedRows.length > 0
                ) {
                    this.page += 1;
                }
            })
            .catch((error) => {
                console.error(
                    'Error loading records:',
                    error
                );

                this.errorMessage =
                    error?.body?.message ||
                    error?.message ||
                    'Unable to load records.';
            })
            .finally(() => {
                this.isLoading = false;
            });
    }

    get disableNext() {
        return this.isLoading || !this.hasMore;
    }

    get isPrimaryScope() {
        return this.scope === 'primary';
    }

    get primaryScopeClass() {
        return this.scope === 'primary'
            ? 'is-active'
            : '';
    }

    get mineScopeClass() {
        return this.scope === 'mine'
            ? 'is-active'
            : '';
    }

    get allScopeClass() {
        return this.scope === 'all'
            ? 'is-active'
            : '';
    }

    get conflictsViewClass() {
        return this.view === 'conflicts'
            ? 'is-active'
            : '';
    }

    get allViewClass() {
        return this.view === 'all'
            ? 'is-active'
            : '';
    }

    get syncViewClass() {
        return this.view === 'sync'
            ? 'is-active'
            : '';
    }

    get totalApps() {
        return new Set(
            this.rows.map((row) => row.appName)
        ).size;
    }

    get totalRecords() {
        return this.rows.length;
    }

    get totalConflicts() {
        return this.rows.filter(
            (row) =>
                row.paamManual !==
                row.paamDiscovered
        ).length;
    }

    get totalSync() {
        return (
            this.totalRecords -
            this.totalConflicts
        );
    }

    get conflictPct() {
        if (!this.totalRecords) {
            return 0;
        }

        return Math.round(
            (
                this.totalConflicts /
                this.totalRecords
            ) * 100
        );
    }

    get totalAppsDisplay() {
        return formatNumber(this.totalApps);
    }

    get totalRecordsDisplay() {
        return formatNumber(
            this.totalRecordCount
        );
    }

    get totalConflictsDisplay() {
        return formatNumber(
            this.totalConflicts
        );
    }

    get totalSyncDisplay() {
        return formatNumber(this.totalSync);
    }

    get filteredRowsRaw() {
        let filteredRows = this.rows.map(
            (row) => ({
                ...row,
                isConflict:
                    row.paamManual !==
                    row.paamDiscovered
            })
        );

        if (this.view === 'conflicts') {
            filteredRows = filteredRows.filter(
                (row) => row.isConflict
            );
        } else if (this.view === 'sync') {
            filteredRows = filteredRows.filter(
                (row) => !row.isConflict
            );
        }

        if (this.statusFilter !== 'all') {
            filteredRows = filteredRows.filter(
                (row) => {
                    const manualStatus =
                        statusSlug(
                            row.manualStatus ||
                            'Unknown'
                        );

                    const discoveredStatus =
                        statusSlug(
                            row.discoveredStatus ||
                            'Unknown'
                        );

                    return (
                        manualStatus ===
                            this.statusFilter ||
                        discoveredStatus ===
                            this.statusFilter
                    );
                }
            );
        }

        filteredRows.sort((firstRow, secondRow) => {
            const firstAppName = String(
                firstRow.appName || ''
            ).toLowerCase();

            const secondAppName = String(
                secondRow.appName || ''
            ).toLowerCase();

            if (
                firstAppName !== secondAppName &&
                this.sortField !== 'appName'
            ) {
                return firstAppName <
                    secondAppName
                    ? -1
                    : 1;
            }

            const firstValue = String(
                firstRow[this.sortField] ?? ''
            ).toLowerCase();

            const secondValue = String(
                secondRow[this.sortField] ?? ''
            ).toLowerCase();

            if (firstValue < secondValue) {
                return this.sortDir === 'asc'
                    ? -1
                    : 1;
            }

            if (firstValue > secondValue) {
                return this.sortDir === 'asc'
                    ? 1
                    : -1;
            }

            return 0;
        });

        return filteredRows;
    }

    get filteredCountDisplay() {
        return formatNumber(
            this.filteredRowsRaw.length
        );
    }

    get pageRows() {
        const styledRows =
            this.filteredRowsRaw.map((row) => {
                const operationalStatus =
                    row.status || 'Unknown';

                const discoveredStatus =
                    row.discoveredStatus ||
                    'Unknown';

                const manualSlug =
                    statusSlug(
                        operationalStatus
                    );

                const discoveredSlug =
                    statusSlug(
                        discoveredStatus
                    );

                const wasOverridden =
                    this.overrides[row.id] !==
                    undefined;

                return {
                    ...row,

                    groupKey:
                        row.appId ||
                        row.appName ||
                        row.id,

                    manualPillClass:
                        `paam-pill paam-pill--${manualSlug} ` +
                        `${
                            row.isConflict
                                ? 'paam-pill--diff'
                                : ''
                        }`,

                    discoveredPillClass:
                        `paam-pill paam-pill--${discoveredSlug} ` +
                        `${
                            row.isConflict
                                ? 'paam-pill--diff'
                                : ''
                        }`,

                    manualTitle:
                        `${row.paamManual} — ` +
                        `${operationalStatus}`,

                    discoveredTitle:
                        `${row.paamDiscovered} — ` +
                        `${discoveredStatus}`,

                    diffTitle:
                        `Will change to ` +
                        `${row.paamDiscovered}`,

                    syncStatusClass:
                        row.isConflict
                            ? 'paam-status paam-status--conflict'
                            : 'paam-status paam-status--sync',

                    syncStatusLabel:
                        row.isConflict
                            ? 'Conflict'
                            : 'In Sync',

                    acceptTitle:
                        `Replace PAAM Manual ` +
                        `(${row.paamManual}) with ` +
                        `PAAM Discovered ` +
                        `(${row.paamDiscovered})`,

                    wasOverridden
                };
            });

        const groupSizes = new Map();

        styledRows.forEach((row) => {
            const currentGroupSize =
                groupSizes.get(
                    row.groupKey
                ) || 0;

            groupSizes.set(
                row.groupKey,
                currentGroupSize + 1
            );
        });

        const renderedGroups = new Set();

        return styledRows.map((row) => {
            const showApplication =
                !renderedGroups.has(
                    row.groupKey
                );

            if (showApplication) {
                renderedGroups.add(
                    row.groupKey
                );
            }

            return {
                ...row,

                showApplication,

                applicationRowSpan:
                    showApplication
                        ? groupSizes.get(
                            row.groupKey
                        )
                        : null,

                rowClass:
                    `${
                        row.isConflict
                            ? 'paam-row-conflict '
                            : ''
                    }` +
                    `${
                        showApplication
                            ? 'paam-row-group-start'
                            : 'paam-row-group-member'
                    }`
            };
        });
    }

    get totalPages() {
        return Math.max(
            1,
            Math.ceil(
                this.totalRecordCount /
                Number(this.pageSize)
            )
        );
    }

    get currentPage() {
        return Math.min(
            this.page,
            this.totalPages
        );
    }

    get footerRangeLabel() {
        if (this.totalRecordCount === 0) {
            return 'Showing 0–0 of 0';
        }

        const start =
            (
                (this.page - 1) *
                Number(this.pageSize)
            ) + 1;

        const end = Math.min(
            start + this.rows.length - 1,
            this.totalRecordCount
        );

        return (
            `Showing ${formatNumber(start)}–` +
            `${formatNumber(end)} of ` +
            `${formatNumber(this.totalRecordCount)}`
        );
    }

    get hasPageRows() {
        return this.pageRows.length > 0;
    }

    get emptyColspan() {
        return this.isPrimaryScope
            ? 6
            : 5;
    }

    get isFirstPage() {
        return this.currentPage === 1;
    }

    get isLastPage() {
        return (
            this.currentPage ===
            this.totalPages
        );
    }

    get appSortArrow() {
        return this.getSortArrow(
            'appName'
        );
    }

    get statusSortArrow() {
        return this.getSortArrow(
            'status'
        );
    }

    get manualSortArrow() {
        return this.getSortArrow(
            'paamManual'
        );
    }

    get discoveredSortArrow() {
        return this.getSortArrow(
            'paamDiscovered'
        );
    }

    get toastClass() {
        return (
            `paam-toast ` +
            `paam-toast--${this.toastKind}`
        );
    }

    getSortArrow(field) {
        if (this.sortField !== field) {
            return '↕';
        }

        return this.sortDir === 'asc'
            ? '↑'
            : '↓';
    }

    resetPage() {
        this.page = 1;
    }

    resetServerPagination() {
        this.page = 1;
        this.rows = [];
        this.lastCreatedDate = null;
        this.lastRecordId = null;
        this.hasMore = true;
        this.totalRecordCount = 0;
    }

    handleSearch(event) {
        const searchValue =
            event.target.value || '';

        this.query = searchValue;

        window.clearTimeout(
            this.searchTimeout
        );

        this.searchTimeout =
            window.setTimeout(() => {
                const trimmedSearch =
                    this.query.trim();

                if (
                    trimmedSearch.length > 0 &&
                    trimmedSearch.length < 3
                ) {
                    return;
                }

                this.resetServerPagination();
                this.loadRecords();
            }, 400);
    }

    handleScopeChange(event) {
        const selectedScope =
            event.currentTarget.dataset.scope;

        if (
            this.scope === selectedScope ||
            this.isLoading
        ) {
            return;
        }

        this.scope = selectedScope;

        this.resetServerPagination();
        this.loadRecords();
    }

    handleViewChange(event) {
        this.view =
            event.currentTarget.dataset.view;

        this.resetPage();
    }

    handleStatusFilterChange(event) {
        this.statusFilter =
            event.target.value;

        this.resetPage();
    }

    handleSort(event) {
        const field =
            event.currentTarget.dataset.field;

        if (this.sortField === field) {
            this.sortDir =
                this.sortDir === 'asc'
                    ? 'desc'
                    : 'asc';
        } else {
            this.sortField = field;
            this.sortDir = 'asc';
        }

        this.resetPage();
    }

    handleAccept(event) {
        const id =
            event.currentTarget.dataset.id;

        const row = this.rows.find(
            (record) => record.id === id
        );

        if (
            !row ||
            row.paamManual ===
                row.paamDiscovered
        ) {
            return;
        }

        const originalManual =
            row.paamManual;

        this.rows = this.rows.map(
            (record) =>
                record.id === id
                    ? {
                        ...record,
                        paamManual:
                            row.paamDiscovered
                    }
                    : record
        );

        this.overrides = {
            ...this.overrides,
            [id]: originalManual
        };

        this.showToast(
            'success',
            `Accepted “${row.paamDiscovered}” ` +
            `for ${row.appName}`
        );
    }

    handleUndo(event) {
        const id =
            event.currentTarget.dataset.id;

        const original =
            this.overrides[id];

        if (original === undefined) {
            return;
        }

        this.rows = this.rows.map(
            (record) =>
                record.id === id
                    ? {
                        ...record,
                        paamManual: original
                    }
                    : record
        );

        const nextOverrides = {
            ...this.overrides
        };

        delete nextOverrides[id];

        this.overrides =
            nextOverrides;

        this.showToast(
            'success',
            `Reverted to “${original}”`
        );
    }

    handlePageSizeChange(event) {
        this.pageSize =
            Number(event.target.value);

        this.resetServerPagination();
        this.loadRecords();
    }

    goFirst() {
        if (
            this.isLoading ||
            this.isFirstPage
        ) {
            return;
        }

        this.resetServerPagination();
        this.loadRecords();
    }

    goPrev() {
        if (
            this.isLoading ||
            this.isFirstPage
        ) {
            return;
        }

        this.resetServerPagination();
        this.loadRecords();
    }

    goNext() {
        if (
            this.isLoading ||
            !this.hasMore
        ) {
            return;
        }

        this.loadRecords(true);
    }

    goLast() {
        if (
            this.isLoading ||
            this.isLastPage
        ) {
            return;
        }

        this.showToast(
            'warning',
            'Use Next to load additional records.'
        );
    }

    showToast(kind, message) {
        this.toastKind = kind;
        this.toastMessage = message;

        window.clearTimeout(
            this.toastTimeout
        );

        this.toastTimeout =
            window.setTimeout(() => {
                this.toastMessage = '';
            }, 3500);
    }

    dismissToast() {
        this.toastMessage = '';
    }
}
