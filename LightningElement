connectedCallback() {
    pubsub.subscribe('buttonClicked', this.handleButtonClicked);

    this.showFilter = true;

    console.log(
        'this.selectedFiltersMap callback ',
        JSON.stringify(this.selectedFiltersMap)
    );

    // ONLY restore during back navigation
    if (this.selectedFiltersMap) {

        this.isBackNavigation = true;

        this.selectedFiltersdata = {
            ...this.selectedFiltersMap
        };

        console.log(
            'this.selectedFiltersdata callback ',
            JSON.stringify(this.selectedFiltersdata)
        );

        if (this.selectedFilters && this.selectedFilters.length > 0) {

            const selectedFieldNames = this.selectedFilters
                .map(item => Object.keys(item)[0])
                .filter(key => key !== 'uniqueKey');

            console.log(
                'selectedFieldNames ',
                JSON.stringify(selectedFieldNames)
            );

            this.loadFilterValues(selectedFieldNames);
        }
    }

    console.log(
        'Restored selectedFiltersdata:',
        JSON.stringify(this.selectedFiltersdata)
    );

    console.log('checking connected callback');
}


