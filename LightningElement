@AuraEnabled(cacheable=true)
    public static PaamPageResult getStackLayJunction(
        Integer pageSize,
        Datetime lastCreatedDate,
        Id lastRecordId,
        String ownedBy,
        String searchKey
    ) {
        Integer safeLimit = pageSize == null
            ? 50
            : Math.min(Math.max(pageSize, 1), 200);

        Integer queryLimit = safeLimit + 1;

        Id currentUserId = UserInfo.getUserId();

        /*
         * Ownership condition:
         *
         * MyPrimary:
         *   Primary ownership fields only.
         *
         * MyAll:
         *   Primary and delegate ownership fields.
         *
         * All:
         *   No ownership condition.
         */
        String ownershipCondition =
            buildOwnershipCondition(ownedBy);

        /*
         * Search is applied only when at least three
         * non-space characters are entered.
         */
        String normalizedSearchKey =
            String.isBlank(searchKey)
                ? null
                : searchKey.trim();

        String searchPattern;

        if (
            normalizedSearchKey != null &&
            normalizedSearchKey.length() >= 3
        ) {
            searchPattern =
                '%' + normalizedSearchKey + '%';
        }

        /*
         * These conditions apply to both the count query
         * and the record query.
         */
        List<String> baseConditions =
            new List<String>();

        if (String.isNotBlank(ownershipCondition)) {
            baseConditions.add(ownershipCondition);
        }

        if (String.isNotBlank(searchPattern)) {
            baseConditions.add(
                '(' +
                    'TPM_App_Stack__r.App__r.Name ' +
                    'LIKE :searchPattern ' +

                    'OR TPM_App_Stack__r.App__r.' +
                    'Operational_Status__c ' +
                    'LIKE :searchPattern ' +

                    'OR Stack_Layer_Config__r.Name ' +
                    'LIKE :searchPattern ' +

                    'OR Stack_Layer_Status__c ' +
                    'LIKE :searchPattern' +
                ')'
            );
        }

        /*
         * Count query.
         *
         * The same ownership and search filters must be
         * used here so totalRecords is accurate.
         */
        String countQuery =
            'SELECT COUNT() ' +
            'FROM TPM_Stack_Layer_Junction__c';

        if (!baseConditions.isEmpty()) {
            countQuery +=
                ' WHERE ' +
                String.join(baseConditions, ' AND ');
        }

        Integer totalRecordCount =
            Database.countQuery(countQuery);

        /*
         * Record query conditions start with the ownership
         * and search conditions.
         */
        List<String> recordConditions =
            new List<String>();

        recordConditions.addAll(baseConditions);

        /*
         * Keyset pagination.
         */
        if (
            lastCreatedDate != null &&
            lastRecordId != null
        ) {
            recordConditions.add(
                '(' +
                    'CreatedDate < :lastCreatedDate ' +
                    'OR (' +
                        'CreatedDate = :lastCreatedDate ' +
                        'AND Id < :lastRecordId' +
                    ')' +
                ')'
            );
        }

        String recordQuery =
            'SELECT ' +
                'Id, ' +
                'CreatedDate, ' +
                'Stack_Layer_Status__c, ' +
                'Stack_Layer_Config__r.Name, ' +
                'TPM_App_Stack__r.App__c, ' +
                'TPM_App_Stack__r.App__r.Name, ' +
                'TPM_App_Stack__r.App__r.' +
                    'Operational_Status__c ' +
            'FROM TPM_Stack_Layer_Junction__c';

        if (!recordConditions.isEmpty()) {
            recordQuery +=
                ' WHERE ' +
                String.join(recordConditions, ' AND ');
        }

        recordQuery +=
            ' ORDER BY CreatedDate DESC, Id DESC' +
            ' LIMIT :queryLimit';

        List<TPM_Stack_Layer_Junction__c> queriedRecords =
            Database.query(recordQuery);

        Boolean hasMore =
            queriedRecords.size() > safeLimit;

        /*
         * The query requests one extra record to determine
         * whether another page exists.
         */
        List<TPM_Stack_Layer_Junction__c> pageRecords =
            new List<TPM_Stack_Layer_Junction__c>();

        Integer recordsToReturn = Math.min(
            safeLimit,
            queriedRecords.size()
        );

        for (
            Integer index = 0;
            index < recordsToReturn;
            index++
        ) {
            pageRecords.add(queriedRecords[index]);
        }

        List<PaamRowWrapper> rows =
            new List<PaamRowWrapper>();

        for (
            TPM_Stack_Layer_Junction__c recordItem :
            pageRecords
        ) {
            PaamRowWrapper row =
                new PaamRowWrapper();

            row.Id = recordItem.Id;
            row.createdDate = recordItem.CreatedDate;

            row.manualStatus =
                recordItem.Stack_Layer_Status__c;

            if (
                recordItem.Stack_Layer_Config__r != null
            ) {
                row.paamManual =
                    recordItem
                        .Stack_Layer_Config__r
                        .Name;
            }

            if (
                recordItem.TPM_App_Stack__r != null &&
                recordItem.TPM_App_Stack__r.App__r != null
            ) {
                row.appId =
                    recordItem
                        .TPM_App_Stack__r
                        .App__c;

                row.appName =
                    recordItem
                        .TPM_App_Stack__r
                        .App__r
                        .Name;

                row.operationalStatus =
                    recordItem
                        .TPM_App_Stack__r
                        .App__r
                        .Operational_Status__c;
            }

            row.appName =
                String.isBlank(row.appName)
                    ? ''
                    : row.appName;

            row.operationalStatus =
                String.isBlank(row.operationalStatus)
                    ? ''
                    : row.operationalStatus;

            row.paamManual =
                String.isBlank(row.paamManual)
                    ? ''
                    : row.paamManual;

            row.paamDiscovered =
                String.isBlank(row.paamDiscovered)
                    ? ''
                    : row.paamDiscovered;

            row.manualStatus =
                String.isBlank(row.manualStatus)
                    ? ''
                    : row.manualStatus;

            row.discoveredStatus =
                String.isBlank(row.discoveredStatus)
                    ? ''
                    : row.discoveredStatus;

            rows.add(row);
        }

        PaamPageResult result =
            new PaamPageResult();

        result.rows = rows;
        result.hasMore = hasMore;
        result.totalRecords = totalRecordCount;

        /*
         * Return the final record's values as the cursor
         * for the next page.
         */
        if (!pageRecords.isEmpty()) {
            TPM_Stack_Layer_Junction__c finalRecord =
                pageRecords[
                    pageRecords.size() - 1
                ];

            result.lastCreatedDate =
                finalRecord.CreatedDate;

            result.lastRecordId =
                finalRecord.Id;
        }

        return result;
    }

    /**
     * Builds the ownership condition for the TPM App.
     *
     * MyPrimary:
     * Checks only the three primary ownership fields.
     *
     * MyAll:
     * Checks primary and delegate ownership fields.
     *
     * All:
     * Returns null so no ownership filter is applied.
     */
    private static String buildOwnershipCondition(
        String ownedBy
    ) {
        if (
            String.isBlank(ownedBy) ||
            'All'.equalsIgnoreCase(ownedBy)
        ) {
            return null;
        }

        List<String> ownedByFields =
            new List<String>();

        if ('MyPrimary'.equalsIgnoreCase(ownedBy)) {
            ownedByFields.addAll(
                new List<String>{
                    'IT_Architect__c',
                    'Application_Owner__c',
                    'Business_Owner__c'
                }
            );
        } else if (
            'MyAll'.equalsIgnoreCase(ownedBy)
        ) {
            ownedByFields.addAll(
                new List<String>{
                    'IT_Architect__c',
                    'IT_Architect_Delegate_1__c',
                    'IT_Architect_Delegate_2__c',

                    'Application_Owner__c',
                    'Application_Owner_Delegate_1__c',
                    'Application_Owner_Delegate_2__c',
                    'Application_Owner_Delegate_3__c',
                    'Application_Owner_Delegate_4__c',

                    'Business_Owner__c',
                    'Business_Owner_Delegate_1__c',
                    'Business_Owner_Delegate_2__c',
                    'Business_Owner_Delegate_3__c'
                }
            );
        } else {
            return null;
        }

        List<String> ownershipConditions =
            new List<String>();

        for (String fieldName : ownedByFields) {
            ownershipConditions.add(
                'TPM_App_Stack__r.App__r.' +
                fieldName +
                ' = :currentUserId'
            );
        }

        return
            '(' +
            String.join(
                ownershipConditions,
                ' OR '
            ) +
            ')';
    }

    public class PaamPageResult {
        @AuraEnabled
        public List<PaamRowWrapper> rows;

        @AuraEnabled
        public Boolean hasMore;

        @AuraEnabled
        public Integer totalRecords;

        @AuraEnabled
        public Datetime lastCreatedDate;

        @AuraEnabled
        public Id lastRecordId;
    }

    public class PaamRowWrapper {
        @AuraEnabled
        public Id Id;

        @AuraEnabled
        public Datetime createdDate;

        @AuraEnabled
        public Id appId;

        @AuraEnabled
        public String appName;

        @AuraEnabled
        public String operationalStatus;

        @AuraEnabled
        public String paamManual;

        @AuraEnabled
        public String paamDiscovered;

        @AuraEnabled
        public String manualStatus;

        @AuraEnabled
        public String discoveredStatus;

        @AuraEnabled
        public Boolean isMine;

        @AuraEnabled
        public Boolean isPrimary;
    }
