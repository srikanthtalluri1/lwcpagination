@IsTest
private class TPM_PAAMStackDataTest {

    private static void setName(SObject recordItem, String nameValue) {
        Map<String, Schema.SObjectField> fields =
            recordItem.getSObjectType().getDescribe().fields.getMap();

        if (fields.containsKey('Name')) {
            Schema.DescribeFieldResult nameField =
                fields.get('Name').getDescribe();

            if (nameField.isCreateable() && !nameField.isAutoNumber()) {
                recordItem.put('Name', nameValue);
            }
        }
    }

    private static String getPicklistValue(
        Schema.DescribeFieldResult fieldDescribe
    ) {
        for (Schema.PicklistEntry entry :
            fieldDescribe.getPicklistValues()
        ) {
            if (entry.isActive()) {
                return entry.getValue();
            }
        }

        return null;
    }

    @IsTest
    static void testGetStackLayJunction() {
        String uniqueValue =
            String.valueOf(DateTime.now().getTime());

        String employeeNumber =
            'EMP' + uniqueValue;

        User testUser = new User(
            FirstName = 'PAAM',
            LastName = 'Tester',
            Alias = 'paamtest',
            Email = 'paamtest' + uniqueValue + '@test.com',
            Username = 'paamtest' + uniqueValue + '@test.com',
            ProfileId = UserInfo.getProfileId(),
            EmployeeNumber = employeeNumber,
            TimeZoneSidKey = 'America/Chicago',
            LocaleSidKey = 'en_US',
            EmailEncodingKey = 'UTF-8',
            LanguageLocaleKey = 'en_US'
        );

        insert testUser;

        System.runAs(testUser) {
            UCH_Employee__c employee =
                new UCH_Employee__c(
                    Employee_ID__c = employeeNumber
                );

            setName(employee, 'Coverage Employee');
            insert employee;

            Schema.SObjectType appObjectType =
                TPM_App_Stack__c.App__c
                    .getDescribe()
                    .getReferenceTo()[0];

            SObject appRecord =
                appObjectType.newSObject();

            setName(appRecord, 'Coverage Application');

            appRecord.put(
                'App_Name__c',
                'Coverage Application'
            );

            appRecord.put(
                'InActive__c',
                false
            );

            appRecord.put(
                'IT_Architect__c',
                employee.Id
            );

            appRecord.put(
                'Application_Owner__c',
                employee.Id
            );

            appRecord.put(
                'Business_Owner__c',
                employee.Id
            );

            Schema.DescribeFieldResult operationalStatusField =
                appObjectType
                    .getDescribe()
                    .fields
                    .getMap()
                    .get('Operational_Status__c')
                    .getDescribe();

            String operationalStatus =
                getPicklistValue(operationalStatusField);

            if (operationalStatus != null) {
                appRecord.put(
                    'Operational_Status__c',
                    operationalStatus
                );
            }

            insert appRecord;

            TPM_App_Stack__c appStack =
                new TPM_App_Stack__c(
                    App__c = (Id) appRecord.get('Id')
                );

            setName(appStack, 'Coverage App Stack');
            insert appStack;

            Schema.SObjectType configObjectType =
                TPM_Stack_Layer_Junction__c
                    .Stack_Layer_Config__c
                    .getDescribe()
                    .getReferenceTo()[0];

            SObject configRecord =
                configObjectType.newSObject();

            setName(configRecord, 'Coverage Layer');
            insert configRecord;

            String layerStatus =
                getPicklistValue(
                    TPM_Stack_Layer_Junction__c
                        .Stack_Layer_Status__c
                        .getDescribe()
                );

            List<TPM_Stack_Layer_Junction__c> junctions =
                new List<TPM_Stack_Layer_Junction__c>();

            for (Integer index = 0; index < 2; index++) {
                TPM_Stack_Layer_Junction__c junction =
                    new TPM_Stack_Layer_Junction__c(
                        TPM_App_Stack__c = appStack.Id,
                        Stack_Layer_Config__c =
                            (Id) configRecord.get('Id')
                    );

                setName(
                    junction,
                    'Coverage Junction ' + index
                );

                if (layerStatus != null) {
                    junction.Stack_Layer_Status__c =
                        layerStatus;
                }

                junctions.add(junction);
            }

            insert junctions;

            Test.startTest();

            TPM_PAAMStackData.PaamPageResult firstPage =
                TPM_PAAMStackData.getStackLayJunction(
                    1,
                    null,
                    null,
                    'All',
                    'Coverage'
                );

            TPM_PAAMStackData.getStackLayJunction(
                1,
                firstPage.lastCreatedDate,
                firstPage.lastRecordId,
                'All',
                'Coverage'
            );

            TPM_PAAMStackData.getStackLayJunction(
                null,
                null,
                null,
                'MyPrimary',
                'Co'
            );

            TPM_PAAMStackData.getStackLayJunction(
                0,
                null,
                null,
                'MyAll',
                'Coverage'
            );

            TPM_PAAMStackData.getStackLayJunction(
                500,
                System.now(),
                null,
                'Unknown',
                null
            );

            TPM_PAAMStackData.getStackLayJunction(
                10,
                null,
                null,
                null,
                ''
            );

            Test.stopTest();
        }
    }
}
