    /*
     * Creates the App record dynamically.
     *
     * This avoids hard-coding the App object's API name.
     */
    private static Id createApp(
        String appName,
        Boolean isInactive,
        String ownershipField
    ) {
        Schema.SObjectType appStackType =
            getReferenceType(
                TPM_Stack_Layer_Junction__c
                    .TPM_App_Stack__c
            );

        Map<String, Schema.SObjectField> appStackFields =
            appStackType
                .getDescribe()
                .fields
                .getMap();

        System.assert(
            appStackFields.containsKey('App__c'),
            'App__c was not found on the TPM App Stack object.'
        );

        Schema.SObjectType appType =
            getReferenceType(
                appStackFields.get('App__c')
            );

        SObject appRecord =
            appType.newSObject();

        setNameIfCreateable(
            appRecord,
            appName
        );

        setRequiredField(
            appRecord,
            'Inactive__c',
            isInactive
        );

        if (String.isNotBlank(ownershipField)) {
            setRequiredField(
                appRecord,
                ownershipField,
                UserInfo.getUserId()
            );
        }

        setFirstPicklistValue(
            appRecord,
            'Operational_Status__c'
        );

        populateRequiredFields(appRecord);

        insert appRecord;

        return appRecord.Id;
    }


    /*
     * Creates the TPM App Stack parent record dynamically.
     */
    private static Id createAppStack(
        Id appId,
        String stackName
    ) {
        Schema.SObjectType appStackType =
            getReferenceType(
                TPM_Stack_Layer_Junction__c
                    .TPM_App_Stack__c
            );

        SObject appStackRecord =
            appStackType.newSObject();

        setNameIfCreateable(
            appStackRecord,
            stackName
        );

        setRequiredField(
            appStackRecord,
            'App__c',
            appId
        );

        populateRequiredFields(appStackRecord);

        insert appStackRecord;

        return appStackRecord.Id;
    }


    /*
     * Creates the Stack Layer Config parent dynamically.
     */
    private static Id createStackLayerConfig(
        String configName
    ) {
        Schema.SObjectType configType =
            getReferenceType(
                TPM_Stack_Layer_Junction__c
                    .Stack_Layer_Config__c
            );

        SObject configRecord =
            configType.newSObject();

        setNameIfCreateable(
            configRecord,
            configName
        );

        populateRequiredFields(configRecord);

        insert configRecord;

        return configRecord.Id;
    }


    private static TPM_Stack_Layer_Junction__c createJunction(
        Id appStackId,
        Id configId
    ) {
        TPM_Stack_Layer_Junction__c junctionRecord =
            new TPM_Stack_Layer_Junction__c();

        junctionRecord.put(
            'TPM_App_Stack__c',
            appStackId
        );

        junctionRecord.put(
            'Stack_Layer_Config__c',
            configId
        );

        setFirstPicklistValue(
            junctionRecord,
            'Stack_Layer_Status__c'
        );

        populateRequiredFields(junctionRecord);

        insert junctionRecord;

        return junctionRecord;
    }


    private static Set<String> getReturnedAppNames(
        List<POCUI.PaamRowWrapper> rows
    ) {
        Set<String> appNames =
            new Set<String>();

        for (POCUI.PaamRowWrapper row : rows) {
            appNames.add(row.appName);
        }

        return appNames;
    }


    private static Schema.SObjectType getReferenceType(
        Schema.SObjectField lookupField
    ) {
        List<Schema.SObjectType> referenceTypes =
            lookupField
                .getDescribe()
                .getReferenceTo();

        System.assert(
            !referenceTypes.isEmpty(),
            'The supplied field is not a lookup or master-detail field.'
        );

        return referenceTypes[0];
    }


    private static void setRequiredField(
        SObject recordItem,
        String fieldApiName,
        Object fieldValue
    ) {
        Map<String, Schema.SObjectField> fieldMap =
            recordItem
                .getSObjectType()
                .getDescribe()
                .fields
                .getMap();

        System.assert(
            fieldMap.containsKey(fieldApiName),
            'Field not found: ' + fieldApiName
        );

        Schema.DescribeFieldResult fieldDescribe =
            fieldMap
                .get(fieldApiName)
                .getDescribe();

        System.assert(
            fieldDescribe.isCreateable(),
            'Field is not createable: ' + fieldApiName
        );

        recordItem.put(
            fieldApiName,
            fieldValue
        );
    }


    private static void setNameIfCreateable(
        SObject recordItem,
        String nameValue
    ) {
        Map<String, Schema.SObjectField> fieldMap =
            recordItem
                .getSObjectType()
                .getDescribe()
                .fields
                .getMap();

        if (!fieldMap.containsKey('Name')) {
            return;
        }

        Schema.DescribeFieldResult nameDescribe =
            fieldMap
                .get('Name')
                .getDescribe();

        if (
            nameDescribe.isCreateable() &&
            !nameDescribe.isAutoNumber()
        ) {
            recordItem.put(
                'Name',
                nameValue
            );
        }
    }


    private static void setFirstPicklistValue(
        SObject recordItem,
        String fieldApiName
    ) {
        Map<String, Schema.SObjectField> fieldMap =
            recordItem
                .getSObjectType()
                .getDescribe()
                .fields
                .getMap();

        if (!fieldMap.containsKey(fieldApiName)) {
            return;
        }

        Schema.DescribeFieldResult fieldDescribe =
            fieldMap
                .get(fieldApiName)
                .getDescribe();

        if (!fieldDescribe.isCreateable()) {
            return;
        }

        for (
            Schema.PicklistEntry picklistEntry :
            fieldDescribe.getPicklistValues()
        ) {
            if (picklistEntry.isActive()) {
                recordItem.put(
                    fieldApiName,
                    picklistEntry.getValue()
                );

                return;
            }
        }
    }


    /*
     * Populates basic required fields automatically.
     *
     * If your org has validation rules requiring additional
     * business-specific fields, add those fields in the
     * relevant createApp, createAppStack, createStackLayerConfig,
     * or createJunction method.
     */
    private static void populateRequiredFields(
        SObject recordItem
    ) {
        Map<String, Schema.SObjectField> fieldMap =
            recordItem
                .getSObjectType()
                .getDescribe()
                .fields
                .getMap();

        for (String fieldApiName : fieldMap.keySet()) {

            Schema.DescribeFieldResult fieldDescribe =
                fieldMap
                    .get(fieldApiName)
                    .getDescribe();

            if (
                !fieldDescribe.isCreateable() ||
                fieldDescribe.isCalculated() ||
                fieldDescribe.isAutoNumber() ||
                fieldDescribe.isDefaultedOnCreate() ||
                fieldDescribe.isNillable() ||
                recordItem.get(fieldApiName) != null
            ) {
                continue;
            }

            Schema.DisplayType fieldType =
                fieldDescribe.getType();

            if (fieldType == Schema.DisplayType.Boolean) {
                recordItem.put(fieldApiName, false);

            } else if (
                fieldType == Schema.DisplayType.Date
            ) {
                recordItem.put(
                    fieldApiName,
                    Date.today()
                );

            } else if (
                fieldType == Schema.DisplayType.DateTime
            ) {
                recordItem.put(
                    fieldApiName,
                    System.now()
                );

            } else if (
                fieldType == Schema.DisplayType.Time
            ) {
                recordItem.put(
                    fieldApiName,
                    Time.newInstance(12, 0, 0, 0)
                );

            } else if (
                fieldType == Schema.DisplayType.Integer
            ) {
                recordItem.put(fieldApiName, 1);

            } else if (
                fieldType == Schema.DisplayType.Double ||
                fieldType == Schema.DisplayType.Currency ||
                fieldType == Schema.DisplayType.Percent
            ) {
                recordItem.put(fieldApiName, 1);

            } else if (
                fieldType == Schema.DisplayType.Email
            ) {
                recordItem.put(
                    fieldApiName,
                    'test@example.com'
                );

            } else if (
                fieldType == Schema.DisplayType.Url
            ) {
                recordItem.put(
                    fieldApiName,
                    'https://example.com'
                );

            } else if (
                fieldType == Schema.DisplayType.Phone
            ) {
                recordItem.put(
                    fieldApiName,
                    '5125550100'
                );

            } else if (
                fieldType == Schema.DisplayType.String ||
                fieldType == Schema.DisplayType.TextArea
            ) {
                recordItem.put(
                    fieldApiName,
                    'Test'
                );

            } else if (
                fieldType == Schema.DisplayType.Picklist ||
                fieldType == Schema.DisplayType.MultiPicklist
            ) {
                for (
                    Schema.PicklistEntry picklistEntry :
                    fieldDescribe.getPicklistValues()
                ) {
                    if (picklistEntry.isActive()) {
                        recordItem.put(
                            fieldApiName,
                            picklistEntry.getValue()
                        );

                        break;
                    }
                }

            } else if (
                fieldType == Schema.DisplayType.Reference
            ) {
                for (
                    Schema.SObjectType referenceType :
                    fieldDescribe.getReferenceTo()
                ) {
                    if (referenceType == User.SObjectType) {
                        recordItem.put(
                            fieldApiName,
                            UserInfo.getUserId()
                        );

                        break;
                    }
                }
            }
        }
    }
