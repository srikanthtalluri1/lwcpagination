    }));

    if (this.scope === 'mine') {
      out = out.filter((r) => r.isMine);
    } else if (this.scope === 'primary') {
      out = out.filter((r) => r.isPrimary);
    }

    if (this.view === 'conflicts') {
      out = out.filter((r) => r.isConflict);
    } else if (this.view === 'sync') {
      out = out.filter((r) => !r.isConflict);
    }

   /* if (this.statusFilter !== 'all') {
      out = out.filter((r) => {
        const manualStatus = statusSlug(STACK_STATUS.get(r.paamManual) || 'Unknown');
        const discoveredStatus = statusSlug(STACK_STATUS.get(r.paamDiscovered) || 'Unknown');
        return manualStatus === this.statusFilter || discoveredStatus === this.statusFilter;
      });
    } */
    if (this.statusFilter !== 'all') {
    out = out.filter((r) => {
        const manualStatus = statusSlug(r.manualStatus || 'Unknown');
        const discoveredStatus = statusSlug(r.discoveredStatus || 'Unknown');

        return manualStatus === this.statusFilter || discoveredStatus === this.statusFilter;
    });
}

    if (this.query.trim()) {
      const q = this.query.trim().toLowerCase();
      out = out.filter((r) =>
        r.appName.toLowerCase().includes(q) ||
        (r.status || '').toLowerCase().includes(q) ||
        (r.attribute || '').toLowerCase().includes(q) ||
        r.paamManual.toLowerCase().includes(q) ||
        r.paamDiscovered.toLowerCase().includes(q)
      );
    }

    out.sort((a, b) => {
      if (a.appName !== b.appName && this.sortField !== 'appName') {
        return a.appName.toLowerCase() < b.appName.toLowerCase() ? -1 : 1;
      }

      const va = String(a[this.sortField] ?? '').toLowerCase();
      const vb = String(b[this.sortField] ?? '').toLowerCase();

      if (va < vb) return this.sortDir === 'asc' ? -1 : 1;
      if (va > vb) return this.sortDir === 'asc' ? 1 : -1;
      return 0;
    });

    return out;
  }

  get filteredCountDisplay() {
    return formatNumber(this.filteredRowsRaw.length);
  }

 /* get totalPages() {
    return Math.max(
        1,
        Math.ceil(
            this.totalRecordCount / Number(this.pageSize)
        )
    );
  } */

  get currentPage() {
    return Math.min(this.page, this.totalPages);
  }

  get pageStart() {
    return (this.currentPage - 1) * Number(this.pageSize);
  }

  get pageRows() {
    return this.filteredRowsRaw.map((row) => {
        const manualStatus = row.manualStatus || 'Unknown';
        const discoveredStatus = row.discoveredStatus || 'Unknown';
        const manualSlug = statusSlug(manualStatus);
        const discoveredSlug = statusSlug(discoveredStatus);
        const wasOverridden = this.overrides[row.id] !== undefined;

        return {
            ...row,
            rowClass:
                (row.isConflict ? 'paam-row-conflict ' : '') +
                'paam-row-group-start',

            manualPillClass:
                `paam-pill paam-pill--${manualSlug} ` +
                `${row.isConflict ? 'paam-pill--diff' : ''}`,

            discoveredPillClass:
                `paam-pill paam-pill--${discoveredSlug} ` +
                `${row.isConflict ? 'paam-pill--diff' : ''}`,

            manualTitle:
                `${row.paamManual} — ${manualStatus}`,

            discoveredTitle:
                `${row.paamDiscovered} — ${discoveredStatus}`,

            diffTitle:
                `Will change to ${row.paamDiscovered}`,

            syncStatusClass:
                row.isConflict
                    ? 'paam-status paam-status--conflict'
                    : 'paam-status paam-status--sync',

            syncStatusLabel:
                row.isConflict
                    ? 'Conflict'
                    : 'In Sync',

            acceptTitle:
                `Replace PAAM Manual (${row.paamManual}) ` +
                `with PAAM Discovered (${row.paamDiscovered})`,

            wasOverridden
        };
    });
}

get totalPages() {
    return Math.max(
        1,
        Math.ceil(
            this.totalRecordCount / Number(this.pageSize)
        )
    );
}

get footerRangeLabel() {
    if (this.totalRecordCount === 0) {
        return 'Showing 0–0 of 0';
    }

    const start =
        ((this.page - 1) * Number(this.pageSize)) + 1;

    const end = Math.min(
        start + this.rows.length - 1,
        this.totalRecordCount
    );

    return `Showing ${formatNumber(start)}–${formatNumber(end)} of ${formatNumber(this.totalRecordCount)}`;
}

  get hasPageRows() {
    return this.pageRows.length > 0;
  }

  get emptyColspan() {
    return this.isPrimaryScope ? 6 : 5;
  }

  get isFirstPage() {
    return this.currentPage === 1;
  }

  get isLastPage() {
    return this.currentPage === this.totalPages;
  }

