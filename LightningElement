 @AuraEnabled(cacheable=true)
public static PaamPageResult getStackLayJunction(
    Integer pageSize,
    Datetime lastCreatedDate,
    Id lastRecordId
) {
    Integer safeLimit = pageSize == null
        ? 50
        : Math.min(Math.max(pageSize, 1), 200);

    Integer queryLimit = safeLimit + 1;

    Integer totalRecordCount = [
        SELECT COUNT()
        FROM TPM_Stack_Layer_Junction__c
    ];

    List<TPM_Stack_Layer_Junction__c> queriedRecords;

    if (lastCreatedDate == null || lastRecordId == null) {
        queriedRecords = [
            SELECT Id,
                   CreatedDate,
                   Stack_Layer_Status__c,
                   Stack_Layer_Config__r.Name,
                   Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Name,
                   Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Operational_Status__c
            FROM TPM_Stack_Layer_Junction__c
            ORDER BY CreatedDate DESC, Id DESC
            LIMIT :queryLimit
        ];
    } else {
        queriedRecords = [
            SELECT Id,
                   CreatedDate,
                   Stack_Layer_Status__c,
                   Stack_Layer_Config__r.Name,
                   Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Name,
                   Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Operational_Status__c
            FROM TPM_Stack_Layer_Junction__c
            WHERE CreatedDate < :lastCreatedDate
               OR (
                   CreatedDate = :lastCreatedDate
                   AND Id < :lastRecordId
               )
            ORDER BY CreatedDate DESC, Id DESC
            LIMIT :queryLimit
        ];
    }

    Boolean hasMore = queriedRecords.size() > safeLimit;

    List<TPM_Stack_Layer_Junction__c> pageRecords =
        new List<TPM_Stack_Layer_Junction__c>();

    Integer recordsToReturn = Math.min(
        safeLimit,
        queriedRecords.size()
    );

    for (Integer index = 0; index < recordsToReturn; index++) {
        pageRecords.add(queriedRecords[index]);
    }

    List<PaamRowWrapper> rows = new List<PaamRowWrapper>();

    for (TPM_Stack_Layer_Junction__c rec : pageRecords) {
        PaamRowWrapper row = new PaamRowWrapper();

        row.Id = rec.Id;
        row.createdDate = rec.CreatedDate;
        row.manualStatus = rec.Stack_Layer_Status__c;

        if (rec.Stack_Layer_Config__r != null) {
            row.paamManual = rec.Stack_Layer_Config__r.Name;

            if (
                rec.Stack_Layer_Config__r.TPM_App_Stack__r != null &&
                rec.Stack_Layer_Config__r.TPM_App_Stack__r.App__r != null
            ) {
                row.appName =
                    rec.Stack_Layer_Config__r
                        .TPM_App_Stack__r
                        .App__r
                        .Name;

                row.operationalStatus =
                    rec.Stack_Layer_Config__r
                        .TPM_App_Stack__r
                        .App__r
                        .Operational_Status__c;
            }
        }

        row.appName = row.appName == null ? '' : row.appName;

        row.operationalStatus =
            row.operationalStatus == null
                ? ''
                : row.operationalStatus;

        row.paamManual =
            row.paamManual == null
                ? ''
                : row.paamManual;

        row.paamDiscovered =
            row.paamDiscovered == null
                ? ''
                : row.paamDiscovered;

        row.manualStatus =
            row.manualStatus == null
                ? ''
                : row.manualStatus;

        row.discoveredStatus =
            row.discoveredStatus == null
                ? ''
                : row.discoveredStatus;

        rows.add(row);
    }

    PaamPageResult result = new PaamPageResult();

    result.rows = rows;
    result.hasMore = hasMore;
    result.totalRecords = totalRecordCount;

    if (!pageRecords.isEmpty()) {
        TPM_Stack_Layer_Junction__c finalRecord =
            pageRecords[pageRecords.size() - 1];

        result.lastCreatedDate = finalRecord.CreatedDate;
        result.lastRecordId = finalRecord.Id;
    }

    return result;
}

