    @IsTest
    static void testKeysetPagination() {

        Test.startTest();

        POCUI.PaamPageResult firstPage =
            POCUI.getStackLayJunction(
                2,
                null,
                null,
                'All',
                null
            );

        POCUI.PaamPageResult secondPage =
            POCUI.getStackLayJunction(
                2,
                firstPage.lastCreatedDate,
                firstPage.lastRecordId,
                'All',
                null
            );

        Test.stopTest();

        System.assertEquals(
            3,
            firstPage.totalRecords,
            'Total record count should include all active records.'
        );

        System.assertEquals(
            2,
            firstPage.rows.size(),
            'First page should contain two records.'
        );

        System.assertEquals(
            true,
            firstPage.hasMore,
            'First page should indicate that another page exists.'
        );

        System.assertNotEquals(
            null,
            firstPage.lastCreatedDate,
            'First page should return a CreatedDate cursor.'
        );

        System.assertNotEquals(
            null,
            firstPage.lastRecordId,
            'First page should return a record ID cursor.'
        );

        /*
         * Based on the CreatedDate values set in @TestSetup,
         * these should be the first two active records.
         */
        System.assertEquals(
            UNOWNED_ACTIVE_APP,
            firstPage.rows[0].appName
        );

        System.assertEquals(
            DELEGATE_ACTIVE_APP,
            firstPage.rows[1].appName
        );

        System.assertEquals(
            3,
            secondPage.totalRecords,
            'Total count should remain three on the second page.'
        );

        System.assertEquals(
            1,
            secondPage.rows.size(),
            'Second page should contain the remaining record.'
        );

        System.assertEquals(
            false,
            secondPage.hasMore,
            'Second page should not have another page.'
        );

        System.assertEquals(
            PRIMARY_ACTIVE_APP,
            secondPage.rows[0].appName
        );
    }


