.paam-pill--preferred {
    background-color: #6da739;
    color: #ffffff;
}

.paam-pill--acceptable {
    background-color: #fffa70;
    color: #181818;
}

.paam-pill--deprecated {
    background-color: #fa9a00;
    color: #181818;
}

.paam-pill--restricted {
    background-color: #ff7c00;
    color: #181818;
}

.paam-pill--denied {
    background-color: #ff6242;
    color: #ffffff;
}

.paam-pill--under-consideration {
    background-color: #969696;
    color: #ffffff;
}

.paam-pill--unknown,
.paam-pill--not-applicable {
    background-color: #e5e5e5;
    color: #181818;
}
.paam-pill--diff {
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.08);
}

.paam-pill__label {
  min-width: 0;
}

/* Sync status */
.paam-status {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
}

.paam-status::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.paam-status--sync {
  background: var(--paam-success-soft);
  color: var(--paam-success);
}

.paam-status--sync::before {
  background: var(--paam-success);
}

.paam-status--conflict {
  background: var(--paam-danger-soft);
  color: var(--paam-danger);
}

.paam-status--conflict::before {
  background: var(--paam-danger);
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.15);
}

.paam-empty {
  padding: 3rem 1rem;
  text-align: center !important;
  color: var(--paam-muted);
}

.paam-empty__icon {
  font-size: 2rem;
  opacity: 0.5;
}

/* Buttons */
.paam-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  appearance: none;
  font: inherit;
  font-size: 0.8rem;
  font-weight: 500;
  padding: 0.4rem 0.7rem;
  border-radius: 8px;
  border: 1px solid var(--paam-border);
  background: #fff;
  color: var(--paam-text);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.paam-btn:hover {
  border-color: #cbd5e1;
  background: #f8fafc;
}

.paam-btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(0, 59, 92, 0.2);
  border-color: var(--paam-primary);
}

.paam-btn[disabled] {
  opacity: 0.5;
  cursor: not-allowed;
}

.paam-overridden {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--paam-success);
  margin-top: 0.2rem;
}

.paam-diff-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 24px;
  color: var(--paam-danger);
  opacity: 0.8;
}

.paam-diff-cell {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.paam-btn--accept {
  background: var(--paam-success);
  border-color: var(--paam-success);
  color: #fff;
  padding: 0.4rem 0.85rem;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  border-radius: 999px;
  box-shadow: 0 1px 2px rgba(5, 150, 105, 0.18);
}

.paam-btn--accept:hover {
  background: #047857;
  border-color: #047857;
  box-shadow: 0 2px 6px rgba(5, 150, 105, 0.28);
}

.paam-btn--accept svg {
  width: 14px;
  height: 14px;
}

.paam-action-cell {
  text-align: right !important;
}

.paam-action-stack {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  justify-content: flex-end;
}

.paam-action-undo {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--paam-muted);
  background: #fff;
  border: 1px solid var(--paam-border);
  border-radius: 999px;
  padding: 0.2rem 0.6rem;
  cursor: pointer;
  transition: all 0.15s ease;
}

.paam-action-undo:hover {
  color: var(--paam-text);
  background: #f8fafc;
}

.paam-accepted-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--paam-success);
  background: #e6f4ea;
  border: 1px solid #b7dcc3;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
}

.paam-accepted-tag svg {
  width: 12px;
  height: 12px;
}

.paam-action-empty {
  color: var(--paam-muted);
  font-size: 0.9rem;
}

/* Toast */
.paam-toast-region {
  position: fixed;
  bottom: 1.25rem;
  right: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  z-index: 9999;
  pointer-events: none;
}

.paam-toast {
  pointer-events: auto;
  min-width: 260px;
  max-width: 380px;
  padding: 0.65rem 0.9rem;
  border-radius: 10px;
  font-size: 0.85rem;
  color: #fff;
  background: #0f172a;
  box-shadow: 0 6px 20px rgba(15, 23, 42, 0.22);
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  animation: paam-toast-in 0.18s ease-out;
}

.paam-toast--success {
  background: #047857;
}

.paam-toast--error {
  background: #b91c1c;
}

.paam-toast__close {
  background: transparent;
  border: 0;
  color: inherit;
  opacity: 0.75;
  cursor: pointer;
  font-size: 1rem;
  line-height: 1;
  margin-left: auto;
  padding: 0;
}

.paam-toast__close:hover {
  opacity: 1;
}

@keyframes paam-toast-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Footer */
.paam-card__footer {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--paam-border);
  font-size: 0.82rem;
  color: var(--paam-muted);
  background: #f6f8fa;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.paam-pager {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.paam-page-size-label {
  font-size: 0.8rem;
  color: var(--paam-muted);
}

.paam-page-size {
  font: inherit;
  font-size: 0.8rem;
  padding: 0.2rem 0.4rem;
  border: 1px solid var(--paam-border);
  border-radius: 6px;
  background: #fff;
}

.paam-page-label {
  font-size: 0.82rem;
}

@media (max-width: 900px) {
  .paam-page {
    padding: 1rem;
  }

  .paam-toolbar {
    width: 100%;
  }

  .paam-search input {
    width: 100%;
  }

  .paam-field {
    width: 100%;
  }

  .paam-segmented {
    width: 100%;
  }

  .paam-segmented button {
    flex: 1;
  }
}
.paam-group-cell {
  vertical-align: top;
}

.paam-row-group-start > th,
.paam-row-group-start > td {
  border-top-width: 2px;
}

.paam-row-group-member > td {
  border-top-style: dotted;
}
.paam-table tbody td.paam-cell--manual,
.paam-table thead th:nth-child(3) {
    border-left: 1px solid #d8dde6 !important;
}
