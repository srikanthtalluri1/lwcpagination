handleResetButton(event) {
    // Clear selected filter data
    this.selectedFiltersdata = {};
    this.filters = [];
    this.selectedFilters = [];
    this.checkedAffStdArray = [];
    this._filteredFieldValues=[];

    // Clear checked and selectedValue from UI filter options
    this._filteredFieldValues = this._filteredFieldValues.map(filter => ({
        ...filter,
        selectedValue: [],
        filteredFieldValue: filter.filteredFieldValue.map(option => ({
            ...option,
            checked: false,
            children: option.children
                ? option.children.map(child => ({
                    ...child,
                    checked: false
                }))
                : option.children
        }))
    }));

    // Also reset backup so search does not bring old selected values back
    this._filterOptionsBackup = JSON.parse(JSON.stringify(this._filteredFieldValues));

    // Reset child picklist component safely
    const customPick = this.template.querySelector('c-technology-decision-custom-pick');
    if (customPick) {
        customPick.reset();
    }

    // Send empty filters to parent
    this.dispatchEvent(
        new CustomEvent('filterdata', {
            detail: { value: [] }
        })
    );

    this.dispatchEvent(new CustomEvent('handlerestbuttonclick'));
}
