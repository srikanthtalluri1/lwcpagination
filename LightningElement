function hash(str) {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < str.length; i += 1) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619) >>> 0;
  }
  return h;
}

function statusSlug(status) {
  return (status || 'unknown')
    .toString()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '') || 'unknown';
}

function formatNumber(value) {
  return Number(value || 0).toLocaleString();
}

const PAAM_VALUES = STACK_LAYERS.map((s) => s.n);
const STACK_STATUS = new Map(STACK_LAYERS.map((s) => [s.n, s.s || 'Unknown']));

function paamFor(seed) {
  return PAAM_VALUES[hash(seed) % PAAM_VALUES.length];
}

function buildRecords(apps) {
  const out = [];
  let idCounter = 1;

  apps.forEach((app) => {
    const appName = app.n || 'Unknown';
    const status = app.s || 'Unknown';

    const ownerBucket = hash('owner::' + appName) % 100;
    const isMine = ownerBucket < 40;        // sample UI: more visible rows
    const isPrimary = isMine && (hash('primary::' + appName) % 2 === 0);

    PAAM_ATTRIBUTES.forEach((attr) => {
      const manual = paamFor('manual::' + appName + '::' + attr);
      const conflictBucket = hash('conflict::' + appName + '::' + attr) % 10;
      let discovered = manual;

      if (conflictBucket < 3) {
        const other = PAAM_VALUES.filter((v) => v !== manual);
        discovered = other[conflictBucket % other.length];
      }

      out.push({
        id: String(idCounter++),
        appName,
        status,
        attribute: attr,
        paamManual: manual,
        paamDiscovered: discovered,
        isMine,
        isPrimary
      });
    });
  });

  return out;
}

export default class PaamConflicts extends LightningElement {
  //@track rows = buildRecords(APPLICATIONS);
  @track overrides = {};
  @track rows = [];
  @track isLoading = false;
  @track errorMessage = '';
  //pageSize = 50;
  lastCreatedDate = null;
  lastRecordId = null;
  hasMore = true;
  totalRecordCount = 0;
  page = 1;
  query = '';
  view = 'conflicts';        // conflicts | all | sync
  scope = 'primary';         // primary | mine | all
  statusFilter = 'all';
  sortField = 'appName';
  sortDir = 'asc';
  page = 1;
  pageSize ='50';

  toastMessage = '';
  toastKind = 'success';

  stackStatusOptions = STACK_STATUS_OPTIONS;
  connectedCallback() {
    this.loadRecords();
}
  renderedCallback() {
    const pageSizeSelect = this.template.querySelector('.paam-page-size');

    if (pageSizeSelect && pageSizeSelect.value !== String(this.pageSize)) {
        pageSizeSelect.value = String(this.pageSize);
    }
  }

  get ownedBy() {
    if (this.scope === 'primary') {
        return 'MyPrimary';
    }

    if (this.scope === 'mine') {
        return 'MyAll';
    }

    return 'All';
}

   loadRecords(isNextPage = false) {
    this.isLoading = true;
    this.errorMessage = '';

    getStackLayJunction({
        pageSize: Number(this.pageSize),
        lastCreatedDate: this.lastCreatedDate,
        lastRecordId: this.lastRecordId,
        ownedBy: this.ownedBy,
        searchKey: this.query
    })
        .then((result) => {
            const returnedRows = result?.rows || [];

            this.rows = returnedRows.map((row) => ({
                ...row,
                id: row.Id,
                appName: row.appName || '',
                status: row.operationalStatus || '',
                paamManual: row.paamManual || '',
                paamDiscovered: row.paamDiscovered || '',
                manualStatus: row.manualStatus || '',
                discoveredStatus: row.discoveredStatus || ''
            }));

            this.hasMore = result?.hasMore === true;
            this.totalRecordCount = result?.totalRecords || 0;
            this.lastCreatedDate = result?.lastCreatedDate || null;
            this.lastRecordId = result?.lastRecordId || null;

            if (isNextPage && returnedRows.length > 0) {
                this.page += 1;
            }
        })
        .catch((error) => {
            console.error('Error loading records:', error);

            this.errorMessage =
                error?.body?.message ||
                error?.message ||
                'Unable to load records.';
        })
        .finally(() => {
            this.isLoading = false;
        });
}

