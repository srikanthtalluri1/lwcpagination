import { LightningElement, track } from 'lwc';

export default class PocUI extends LightningElement {
    searchKey = '';
    statusFilter = 'All';

    @track rows = [
        {
            id: '1',
            name: 'Salesforce - Enterprise Licensing Consolidation',
            owner: 'Enterprise Architecture',
            environment: 'Production',
            manualValue: 'Preferred',
            discoveredValue: 'Restricted'
        },
        {
            id: '2',
            name: 'Copado',
            owner: 'DevOps',
            environment: 'Production',
            manualValue: 'Preferred',
            discoveredValue: 'Preferred'
        },
        {
            id: '3',
            name: 'ServiceNow - Change Management',
            owner: 'ITSM',
            environment: 'Production',
            manualValue: 'Acceptable',
            discoveredValue: 'Deprecated'
        }
    ];

    statusOptions = [
        { label: 'All', value: 'All' },
        { label: 'Conflict', value: 'Conflict' },
        { label: 'In Sync', value: 'In Sync' }
    ];

    get totalCount() {
        return this.rows.length;
    }

    get conflictCount() {
        return this.rows.filter(row => row.manualValue !== row.discoveredValue).length;
    }

    get syncCount() {
        return this.rows.filter(row => row.manualValue === row.discoveredValue).length;
    }

    get filteredRows() {
        let data = this.rows.map(row => {
            const isConflict = row.manualValue !== row.discoveredValue;
            const status = isConflict ? 'Conflict' : 'In Sync';

            return {
                ...row,
                isConflict,
                status,
                initials: this.getInitials(row.name),
                rowClass: isConflict ? 'conflict-row' : '',
                manualClass: `pill ${this.getPillClass(row.manualValue)} ${isConflict ? 'pill-diff' : ''}`,
                discoveredClass: `pill ${this.getPillClass(row.discoveredValue)} ${isConflict ? 'pill-diff' : ''}`,
                statusClass: isConflict ? 'status status-conflict' : 'status status-sync'
            };
        });

        if (this.searchKey) {
            const key = this.searchKey.toLowerCase();
            data = data.filter(row =>
                row.name.toLowerCase().includes(key) ||
                row.environment.toLowerCase().includes(key) ||
                row.manualValue.toLowerCase().includes(key) ||
                row.discoveredValue.toLowerCase().includes(key)
            );
        }

        if (this.statusFilter !== 'All') {
            data = data.filter(row => row.status === this.statusFilter);
        }

        return data;
    }

    handleSearch(event) {
        this.searchKey = event.target.value;
    }

    handleStatusChange(event) {
        this.statusFilter = event.detail.value;
    }

    handleAccept(event) {
        const rowId = event.target.dataset.id;

        this.rows = this.rows.map(row => {
            if (row.id === rowId) {
                return {
                    ...row,
                    manualValue: row.discoveredValue
                };
            }
            return row;
        });
    }

    getInitials(name) {
        return name
            .split(' ')
            .filter(word => word.length > 0)
            .slice(0, 2)
            .map(word => word[0])
            .join('')
            .toUpperCase();
    }

    getPillClass(value) {
        const cleanValue = value.toLowerCase().replaceAll(' ', '-');

        switch (cleanValue) {
            case 'preferred':
                return 'pill-preferred';
            case 'acceptable':
                return 'pill-acceptable';
            case 'restricted':
                return 'pill-restricted';
            case 'deprecated':
                return 'pill-deprecated';
            case 'denied':
                return 'pill-denied';
            default:
                return 'pill-unknown';
        }
    }
}


