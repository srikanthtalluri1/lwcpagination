syncFiltersFromUI() {
    const clean = label =>
        label?.replace(/\s*\(.*?\)\s*/g, '').trim() || '';

    let finalFilters = [];

    // 1. Add normal filters like Decision Reason
    Object.keys(this.selectedFiltersdata || {}).forEach(key => {
        if (
            key !== 'Status/Stage' &&
            key !== 'Stage' &&
            this.selectedFiltersdata[key]?.length > 0
        ) {
            finalFilters.push({
                [key]: this.selectedFiltersdata[key]
            });
        }
    });

    // 2. Add Status/Stage from current UI checked values
    const statusStageBlock = this._filteredFieldValues.find(
        f => f.filterFieldApiName === 'Status/Stage'
    );

    if (statusStageBlock) {
        let statusValues = [];
        let stageValues = [];

        statusStageBlock.filteredFieldValue.forEach(parent => {
            if (parent.checked) {
                statusValues.push(clean(parent.label));
            }

            parent.children?.forEach(child => {
                if (child.checked) {
                    stageValues.push(clean(child.label));
                }
            });
        });

        if (statusValues.length > 0) {
            finalFilters.push({
                'Status/Stage': statusValues
            });
        }

        if (stageValues.length > 0) {
            finalFilters.push({
                'Stage': stageValues
            });
        }

        // keep selectedFiltersdata also exactly synced
        delete this.selectedFiltersdata['Status/Stage'];
        delete this.selectedFiltersdata['Stage'];

        if (statusValues.length > 0) {
            this.selectedFiltersdata['Status/Stage'] = statusValues;
        }

        if (stageValues.length > 0) {
            this.selectedFiltersdata['Stage'] = stageValues;
        }
    }

    this.filters = finalFilters;

    console.log('SYNCED FINAL FILTERS => ', JSON.stringify(this.filters));
}

