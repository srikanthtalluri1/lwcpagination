@IsTest
static void testSubmitApproval_AcknowledgeComment_InitialReview() {
    TechnologyDecision__c dec = createBaseDecision(
        'New Technology',
        'Pending Initial Tech Decision Review',
        'Draft'
    );
    dec.Arch_Forum_Review__c = 'Yes';
    update dec;

    createApprovalRecord(dec.Id, 'Pending Initial Tech Decision Review', true, false);

    Test.startTest();
    Boolean ok = technologyDecision_CreateFormHelper.submitApprovalComments(
        dec.Id,
        'Initial review complete',
        'Acknowledge Comment',
        null
    );
    Test.stopTest();

    TechnologyDecision__c refreshed = [
        SELECT Stage__c, Initial_TD_Review_Acknowledged__c
        FROM TechnologyDecision__c
        WHERE Id = :dec.Id
    ];

    System.assertEquals(true, ok);
    System.assertEquals(true, refreshed.Initial_TD_Review_Acknowledged__c);
    System.assertEquals('Pending Arch Forum Review', refreshed.Stage__c);
}

