        Test.startTest();

        POCUI.PaamPageResult result =
            POCUI.getStackLayJunction(
                50,
                null,
                null,
                'MyAll',
                null
            );

        Test.stopTest();

        System.assertEquals(
            2,
            result.totalRecords,
            'MyAll should return primary-owned and delegate-owned active apps.'
        );

        System.assertEquals(
            2,
            result.rows.size()
