:host {
  /* USAA brand palette */
  --paam-bg-start: #eef3f7;
  --paam-bg-end: #f7f3ea;
  --paam-card-bg: #ffffff;
  --paam-border: #d9e0e6;
  --paam-text: #0d2436;
  --paam-muted: #5b6b78;

  --paam-primary: #003B5C;
  --paam-primary-soft: #e5edf3;
  --paam-primary-dark: #002855;

  --paam-gold: #C2A77E;
  --paam-gold-dark: #a78a5e;

  --paam-danger: #B3261E;
  --paam-danger-soft: #fbeae8;
  --paam-success: #1f7a4d;
  --paam-success-soft: #e6f2ec;

  --paam-shadow: 0 10px 30px -12px rgba(0, 40, 85, 0.22),
    0 2px 6px -2px rgba(0, 40, 85, 0.08);

  display: block;
  color: var(--paam-text);
  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.paam-page {
  padding: 2.5rem 1.5rem 3rem;
  max-width: 1200px;
  margin: 0 auto;
  background:
    radial-gradient(1200px 600px at 0% -10%, #d6e2eb 0%, transparent 60%),
    radial-gradient(900px 500px at 100% 0%, #efe6d2 0%, transparent 55%),
    linear-gradient(180deg, var(--paam-bg-start) 0%, var(--paam-bg-end) 100%);
  min-height: 100vh;
}

/* Hero */
.paam-hero {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
  padding: 1.75rem 1.75rem 1.5rem;
  flex-wrap: wrap;
  background:
    linear-gradient(135deg, var(--paam-primary-dark) 0%, var(--paam-primary) 55%, #0a4d72 100%);
  border-radius: 14px;
  border: 1px solid var(--paam-primary-dark);
  box-shadow: 0 14px 32px -16px rgba(0, 40, 85, 0.55);
  overflow: hidden;
}

.paam-hero::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5px;
  background: linear-gradient(180deg, var(--paam-gold) 0%, var(--paam-gold-dark) 100%);
}

.paam-hero::after {
  content: "";
  position: absolute;
  right: -80px;
  top: -80px;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(194, 167, 126, 0.22) 0%, rgba(194, 167, 126, 0) 70%);
  pointer-events: none;
}

.paam-hero > * {
  position: relative;
  z-index: 1;
}

.paam-hero h1 {
  margin: 0;
  font-size: 1.9rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #ffffff;
}

.paam-hero h1 .paam-hero__accent {
  color: var(--paam-gold);
}

.paam-hero p {
  margin: 0.35rem 0 0;
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.95rem;
}

.paam-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.3rem 0.7rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--paam-gold);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(194, 167, 126, 0.45);
  border-radius: 999px;
  margin-bottom: 0.75rem;
  backdrop-filter: blur(2px);
}

.paam-eyebrow::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--paam-gold);
  box-shadow: 0 0 0 3px rgba(194, 167, 126, 0.25);
}

/* Stat cards */
.paam-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 1.25rem;
}

.paam-stat {
  background: var(--paam-card-bg);
  border: 1px solid var(--paam-border);
  border-radius: 14px;
  padding: 1rem 1.1rem;
  box-shadow: var(--paam-shadow);
  position: relative;
  overflow: hidden;
}

.paam-stat__accent {
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
}

.paam-stat--total .paam-stat__accent {
  background: var(--paam-primary);
}

.paam-stat--conflict .paam-stat__accent {
  background: var(--paam-danger);
}

.paam-stat--sync .paam-stat__accent {
  background: var(--paam-success);
}

.paam-stat__label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--paam-muted);
}

.paam-stat__value {
  font-size: 1.85rem;
  font-weight: 700;
  line-height: 1.1;
  margin-top: 0.25rem;
  letter-spacing: -0.02em;
}

.paam-stat__hint {
  margin-top: 0.25rem;
  font-size: 0.78rem;
  color: var(--paam-muted);
}

.paam-stat--conflict .paam-stat__value {
  color: var(--paam-danger);
}

.paam-stat--sync .paam-stat__value {
  color: var(--paam-success);
}

/* Card */
.paam-card {
  background: var(--paam-card-bg);
  border: 1px solid var(--paam-border);
  border-radius: 16px;
  box-shadow: var(--paam-shadow);
  overflow: hidden;
}

.paam-card__header {
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--paam-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  background: linear-gradient(180deg, #f6f8fa 0%, #ffffff 100%);
}

.paam-card__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
}

.paam-card__subtitle {
  font-size: 0.82rem;
  color: var(--paam-muted);
  margin: 0.1rem 0 0;
}

/* Toolbar */
.paam-toolbar {
  display: flex;
  gap: 0.75rem;
  align-items: flex-end;
  flex-wrap: wrap;
}

.paam-field {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.paam-field__label {
  font-size: 0.72rem;
  font-weight: 400;
  color: #444;
  letter-spacing: 0;
}

/* Search input */
.paam-search {
  position: relative;
}

.paam-search input {
  width: 260px;
  max-width: 100%;
  height: 1.875rem;
  padding: 0 0.75rem 0 2rem;
  font: inherit;
  font-size: 0.8125rem;
  line-height: 1.875rem;
  border: 1px solid #aeaeae;
  border-radius: 0.25rem;
  background: #fff;
  color: #181818;
  transition: border-color 0.1s linear, box-shadow 0.1s linear;
  outline: none;
}

.paam-search input::placeholder {
  color: #706e6b;
}

.paam-search input:focus {
  border-color: #1b96ff;
  box-shadow: 0 0 3px #0176d3;
}

.paam-search svg {
  position: absolute;
  left: 0.55rem;
  top: 50%;
  transform: translateY(-50%);
  width: 14px;
  height: 14px;
  color: #706e6b;
  pointer-events: none;
}

/* Picklist */
.paam-select {
  font: inherit;
  font-size: 0.8125rem;
  height: 1.875rem;
  padding: 0 1.75rem 0 0.75rem;
  border: 1px solid #aeaeae;
  border-radius: 0.25rem;
  background: #fff;
  color: #181818;
  cursor: pointer;
  outline: none;
  appearance: none;
  transition: border-color 0.1s linear, box-shadow 0.1s linear;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path fill='%23706e6b' d='M0 0l5 6 5-6z'/></svg>");
  background-repeat: no-repeat;
  background-position: right 0.6rem center;
}

.paam-select:focus {
  border-color: #1b96ff;
  box-shadow: 0 0 3px #0176d3;
}

/* Segmented control */
.paam-segmented {
  display: inline-flex;
  height: 1.875rem;
  border-radius: 0.25rem;
  overflow: hidden;
  background: #fff;
}

.paam-segmented button {
  appearance: none;
  background: #fff;
  border: 1px solid #aeaeae;
  border-right-width: 0;
  font: inherit;
  font-size: 0.8125rem;
  font-weight: 400;
  color: #0176d3;
  padding: 0 0.85rem;
  height: 1.875rem;
  line-height: 1;
  cursor: pointer;
  transition: background 0.1s linear, color 0.1s linear, box-shadow 0.1s linear;
  white-space: nowrap;
}

.paam-segmented button:first-child {
  border-top-left-radius: 0.25rem;
  border-bottom-left-radius: 0.25rem;
}

.paam-segmented button:last-child {
  border-right-width: 1px;
  border-top-right-radius: 0.25rem;
  border-bottom-right-radius: 0.25rem;
}

.paam-segmented button:hover {
  background: #f3f3f3;
}

.paam-segmented button:focus {
  outline: none;
  box-shadow: 0 0 3px #0176d3;
  position: relative;
  z-index: 1;
}

.paam-segmented button.is-active {
  background: #0176d3;
  border-color: #014486;
  color: #fff;
}

.paam-segmented button.is-active:hover {
  background: #014486;
}

/* Table */
.paam-table-wrap {
  overflow-x: auto;
}

.paam-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.92rem;
}

.paam-table thead th {
  background: #f8fafc;
  color: var(--paam-muted);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 600;
  text-align: left;
  padding: 0.7rem 1rem;
  border-bottom: 1px solid var(--paam-border);
  position: sticky;
  top: 0;
  user-select: none;
}

.paam-table thead th button {
  background: none;
  border: 0;
  padding: 0;
  font: inherit;
  color: inherit;
  text-transform: inherit;
  letter-spacing: inherit;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}

.paam-table thead th button:hover {
  color: var(--paam-text);
}

.paam-action-heading {
  text-align: right !important;
}

.paam-table tbody td,
.paam-table tbody th {
  padding: 0.85rem 1rem;
  border-bottom: 1px solid #f1f5f9;
  vertical-align: middle;
  font-weight: 400;
}

.paam-table tbody tr:last-child td,
.paam-table tbody tr:last-child th {
  border-bottom: 0;
}

.paam-table tbody tr:hover {
  background-color: #f4f7fa;
}

.paam-row-conflict {
  background-color: rgba(220, 38, 38, 0.04);
}

.paam-row-conflict:hover {
  background-color: rgba(220, 38, 38, 0.08);
}

.paam-row-group-start td,
.paam-row-group-start th {
  border-top: 2px solid #e2e8f0;
}

.paam-attr {
  font-weight: 500;
  color: #334155;
}

.paam-app-cell {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  text-align: left;
}

.paam-table th[scope="row"],
.paam-table td {
  text-align: left;
}

.paam-app-name {
  font-weight: 500;
  color: var(--paam-text);
}

/* PAAM pill */
.paam-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
  border: 1px solid transparent;
  background: #f1f5f9;
  color: #334155;
  max-width: 280px;
  white-space: normal;
  line-height: 1.25;
  text-align: left;
}
