public with sharing class POCUI {
    @AuraEnabled(cacheable=true)
    public static List<PaamRowWrapper> getStackLayJunction() {
        List<PaamRowWrapper> rows = new List<PaamRowWrapper>();

        // Replace object and field API names based on your org
        for (TPM_Stack_Layer_Junction__c rec : [
            SELECT Id,
                 Stack_Layer_Status__c,Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Name, Stack_Layer_Config__r.Name,TPM_App_Stack__r.App__r.Operational_Status__c  
            FROM TPM_Stack_Layer_Junction__c
            LIMIT 5000
        ]) {
            PaamRowWrapper row = new PaamRowWrapper();
            row.Id = rec.Id;
            row.appName = rec.Stack_Layer_Config__r.TPM_App_Stack__r.App__r != null ? rec.Stack_Layer_Config__r.TPM_App_Stack__r.App__r.Name : '';
            row.operationalStatus = rec.TPM_App_Stack__r.App__r  != null ? rec.TPM_App_Stack__r.App__r.Operational_Status__c  : '';
            //row.attribute = rec.PAAM_Attribute__c;

            row.paamManual = rec.Stack_Layer_Config__r != null ? rec.Stack_Layer_Config__r.Name : '';
           // row.manualStatus = rec.PAAM_Manual__r != null ? rec.PAAM_Manual__r.Stack_Layer_Status__c : '';

           // row.paamDiscovered = rec.PAAM_Discovered__r != null ? rec.PAAM_Discovered__r.Name : '';
           // row.discoveredStatus = rec.PAAM_Discovered__r != null ? rec.PAAM_Discovered__r.Stack_Layer_Status__c : '';

            //row.isMine = rec.Is_Mine__c;
            //row.isPrimary = rec.Is_Primary__c;

            rows.add(row);
        }

        return rows;
    }

    public class PaamRowWrapper {
        @AuraEnabled public Id Id;
        @AuraEnabled public String appName;
        @AuraEnabled public String operationalStatus;
        @AuraEnabled public String attribute;
        @AuraEnabled public String paamManual;
        @AuraEnabled public String paamDiscovered;
        @AuraEnabled public String manualStatus;
        @AuraEnabled public String discoveredStatus;
        @AuraEnabled public Boolean isMine;
        @AuraEnabled public Boolean isPrimary;
    }
}
