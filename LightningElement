 get filterPanelClass() {
    return this.showToggle && this.showFilter
        ? 'custom-border-right child-container'
        : 'custom-border-right child-container slds-hide';
}


 handlefilterdata(event) {
    this.filters = event.detail.value;
    console.log(' this.filters ',  JSON.stringify(this.filters));
    // Save for datatable
    this.savedFilters = event.detail.value;

    // Save for checkbox UI restore
    this.savedFiltersMap = this.convertFilterArrayToMap(event.detail.value);
    console.log(' this.savedFiltersMap ',  JSON.stringify(this.savedFiltersMap));
    const child = this.template.querySelector('c-technology-decision-data-table');
    if (child) {
        child.updatefilters(this.filters);
    }
}

convertFilterArrayToMap(filterArray) {
    let result = {};

    if (filterArray && Array.isArray(filterArray)) {
        filterArray.forEach(item => {
            Object.keys(item).forEach(key => {
                if (key !== 'uniqueKey') {
                    result[key] = item[key];
                }
            });
        });
    }
 console.log(' this.result ',  JSON.stringify(result));
    return result;
}
